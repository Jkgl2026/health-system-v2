/* components/symptom-item/symptom-item.wxss */
.symptom-item {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  transition: all 0.2s ease;
}

.symptom-item:active {
  background: #f5f5f5;
}

.symptom-item.checked {
  background: #eff6ff;
  border: 1rpx solid #bfdbfe;
}

.symptom-item.disabled {
  opacity: 0.5;
  pointer-events: none;
}

.symptom-checkbox {
  margin-right: 16rpx;
}

.checkbox-inner {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
}

.checkbox-inner.checked {
  background: #3b82f6;
  border-color: #3b82f6;
}

.check-icon {
  color: white;
  font-size: 24rpx;
  font-weight: bold;
}

.symptom-content {
  flex: 1;
}

.symptom-main {
  display: flex;
  align-items: center;
  margin-bottom: 4rpx;
}

.symptom-name {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.symptom-category {
  font-size: 22rpx;
  color: #999;
  background: #f3f4f6;
  padding: 2rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.symptom-desc {
  font-size: 24rpx;
  color: #666;
  margin-top: 4rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.severity-badge {
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
  margin-left: 12rpx;
}

.severity-badge.mild {
  background: #dcfce7;
  color: #16a34a;
}

.severity-badge.moderate {
  background: #fef9c3;
  color: #ca8a04;
}

.severity-badge.severe {
  background: #fee2e2;
  color: #dc2626;
}

.severity-badge.emergency {
  background: #fef2f2;
  color: #ef4444;
  border: 1rpx solid #fca5a5;
}
