<!--components/health-score/health-score.wxml-->
<view class="health-score-container">
  <!-- 评分圆环 -->
  <view class="score-ring">
    <view class="score-circle {{colorClass}}">
      <text class="score-value">{{score}}</text>
      <text class="score-unit">分</text>
    </view>
    <view class="score-status" style="color: {{statusColor}}">
      {{statusText}}
    </view>
  </view>
  
  <!-- 健康要素 -->
  <view wx:if="{{showElements && elements.length > 0}}" class="elements-grid">
    <view 
      wx:for="{{elements}}" 
      wx:key="key"
      class="element-item"
    >
      <view class="element-bar" style="width: {{item.value}}%; background: {{item.color}}"></view>
      <text class="element-label">{{item.label}}</text>
      <text class="element-value">{{item.value}}</text>
    </view>
  </view>
  
  <!-- 建议 -->
  <view wx:if="{{showRecommendations && recommendations.length > 0}}" class="recommendations">
    <view class="recommendations-title">调理建议</view>
    <view 
      wx:for="{{recommendations}}" 
      wx:key="index"
      class="recommendation-item"
    >
      <text class="recommendation-dot">•</text>
      <text class="recommendation-text">{{item}}</text>
    </view>
  </view>
</view>
