<!--pages/local-data-recovery/local-data-recovery.wxml-->
<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
      <text>返回</text>
    </view>
    <view class="header-title">本地数据恢复</view>
  </view>

  <!-- 说明卡片 -->
  <view class="info-card">
    <view class="info-icon">💾</view>
    <view class="info-content">
      <view class="info-title">数据恢复工具</view>
      <view class="info-desc">这里可以查看和恢复您本地保存的健康数据，包括症状检查记录、健康分析结果、方案选择等。</view>
    </view>
  </view>

  <!-- 本地存储状态 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">本地存储状态</text>
      <button class="btn-refresh" bindtap="refreshData">
        <text>🔄 刷新</text>
      </button>
    </view>

    <view class="storage-list">
      <view class="storage-item" wx:for="{{storageItems}}" wx:key="key">
        <view class="storage-info">
          <text class="storage-name">{{item.name}}</text>
          <text class="storage-key">{{item.key}}</text>
        </view>
        <view class="storage-status">
          <text class="status-badge {{item.hasData ? 'has-data' : 'no-data'}}">
            {{item.hasData ? '有数据' : '无数据'}}
          </text>
          <text class="storage-size" wx:if="{{item.size}}">{{item.size}}</text>
        </view>
        <view class="storage-actions">
          <button class="btn-small" bindtap="viewData" data-key="{{item.key}}" wx:if="{{item.hasData}}">
            查看
          </button>
          <button class="btn-small danger" bindtap="clearData" data-key="{{item.key}}" wx:if="{{item.hasData}}">
            清除
          </button>
        </view>
      </view>
    </view>
  </view>

  <!-- 快捷操作 -->
  <view class="section">
    <view class="section-title">快捷操作</view>
    
    <view class="action-list">
      <!-- 导出所有数据 -->
      <view class="action-item" bindtap="exportAllData">
        <view class="action-icon">📤</view>
        <view class="action-content">
          <text class="action-title">导出所有数据</text>
          <text class="action-desc">将本地数据导出为文件，可用于备份或迁移</text>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <!-- 导入数据 -->
      <view class="action-item" bindtap="importData">
        <view class="action-icon">📥</view>
        <view class="action-content">
          <text class="action-title">导入数据</text>
          <text class="action-desc">从文件导入之前备份的数据</text>
        </view>
        <text class="action-arrow">›</text>
      </view>

      <!-- 清除所有数据 -->
      <view class="action-item danger" bindtap="clearAllData">
        <view class="action-icon">🗑️</view>
        <view class="action-content">
          <text class="action-title">清除所有本地数据</text>
          <text class="action-desc">删除所有本地保存的健康数据（不可恢复）</text>
        </view>
        <text class="action-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 数据详情弹窗 -->
  <view class="modal" wx:if="{{showDataModal}}" bindtap="closeDataModal">
    <view class="modal-content" catchtap="stopPropagation">
      <view class="modal-header">
        <text class="modal-title">{{currentDataKey}}</text>
        <view class="modal-close" bindtap="closeDataModal">✕</view>
      </view>
      <scroll-view class="modal-body" scroll-y>
        <view class="data-preview">
          <text class="data-text">{{currentDataContent}}</text>
        </view>
      </scroll-view>
      <view class="modal-footer">
        <button class="btn-secondary" bindtap="copyData">复制内容</button>
        <button class="btn-primary" bindtap="closeDataModal">关闭</button>
      </view>
    </view>
  </view>

  <!-- 加载中 -->
  <view class="loading-overlay" wx:if="{{loading}}">
    <view class="loading-content">
      <view class="loading-spinner"></view>
      <text class="loading-text">{{loadingText}}</text>
    </view>
  </view>
</view>
