/* pages/index/index.wxss */
/* 首页样式 - 紧凑版 */

.container {
  min-height: 100vh;
  background: linear-gradient(to bottom right, #eff6ff, #ffffff, #f0fdf4);
  padding-bottom: 100rpx;
}

/* 头部 */
.header {
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 16rpx 24rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.logo {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #3b82f6, #10b981);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 32rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #1f2937;
}

.header-subtitle {
  font-size: 20rpx;
  color: #6b7280;
}

.header-actions {
  display: flex;
  gap: 12rpx;
}

/* 页面切换 */
.page-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #eef2ff;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid #c7d2fe;
}

.page-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.page-num {
  width: 36rpx;
  height: 36rpx;
  background: #6366f1;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 22rpx;
}

.page-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #312e81;
}

/* 健康数据概览 */
.health-overview {
  padding: 16rpx;
}

/* 健康卡片 */
.health-card {
  background: #fff;
  border-radius: 16rpx;
  border: 2rpx solid #e0e7ff;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  overflow: hidden;
  margin-bottom: 16rpx;
}

.card-header {
  background: linear-gradient(90deg, #eef2ff, #eff6ff);
  padding: 16rpx 20rpx;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.card-title-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.card-icon {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #6366f1, #3b82f6);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.card-title {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.card-desc {
  font-size: 20rpx;
  color: #6b7280;
  display: block;
  margin-top: 2rpx;
}

/* 健康评分 */
.score-section {
  padding: 20rpx 16rpx;
}

.score-main {
  background: linear-gradient(135deg, #10b981, #059669);
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
  color: #fff;
}

.score-label {
  font-size: 22rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 4rpx;
}

.score-value {
  font-size: 56rpx;
  font-weight: 700;
  display: block;
}

.score-unit {
  font-size: 20rpx;
  opacity: 0.8;
  display: block;
  margin-top: 4rpx;
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding: 0 16rpx 16rpx;
}

.stat-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 16rpx;
  border: 1rpx solid #e5e7eb;
  position: relative;
  overflow: hidden;
}

.stat-card.stat-blue {
  background: linear-gradient(135deg, #eff6ff, #fff);
  border-color: #bfdbfe;
}

.stat-card.stat-orange {
  background: linear-gradient(135deg, #fff7ed, #fff);
  border-color: #fed7aa;
}

.stat-card.stat-purple {
  background: linear-gradient(135deg, #faf5ff, #fff);
  border-color: #e9d5ff;
}

.stat-card.stat-red {
  background: linear-gradient(135deg, #fef2f2, #fff);
  border-color: #fecaca;
}

.stat-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.stat-label {
  font-size: 20rpx;
  font-weight: 500;
  color: #4b5563;
}

.stat-icon {
  font-size: 24rpx;
}

.stat-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.stat-unit {
  font-size: 18rpx;
  color: #6b7280;
  display: block;
  margin-top: 2rpx;
}

.progress-bar {
  height: 6rpx;
  background: #e5e7eb;
  border-radius: 3rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #10b981);
  border-radius: 3rpx;
}

.stat-extra {
  display: flex;
  justify-content: space-between;
  margin-top: 8rpx;
  padding-top: 8rpx;
  border-top: 1rpx solid #f3f4f6;
}

.extra-label {
  font-size: 18rpx;
  color: #9ca3af;
}

.extra-value {
  font-size: 18rpx;
  font-weight: 600;
  color: #6b7280;
}

.expand-hint {
  display: flex;
  align-items: center;
  gap: 4rpx;
  margin-top: 10rpx;
  font-size: 18rpx;
  color: #9ca3af;
}

.expand-arrow {
  transition: transform 0.3s;
  font-size: 18rpx;
}

.expand-arrow.expanded {
  transform: rotate(90deg);
}

.expanded-content {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
}

.expanded-title {
  font-size: 18rpx;
  color: #6b7280;
  margin-bottom: 8rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  background: #f3f4f6;
  border-radius: 6rpx;
  color: #4b5563;
}

.tag-important {
  background: #fef2f2;
  color: #dc2626;
}

/* 健康改善潜力 */
.potential-section {
  padding: 16rpx;
  background: #f8fafc;
  border-top: 1rpx solid #f1f5f9;
}

.potential-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.potential-icon {
  font-size: 24rpx;
}

.potential-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #475569;
  flex: 1;
}

.potential-value {
  font-size: 22rpx;
  font-weight: 700;
  color: #10b981;
}

.progress-bar-lg {
  height: 20rpx;
  background: #e5e7eb;
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill-lg {
  height: 100%;
  background: linear-gradient(90deg, #10b981, #059669);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  padding-right: 8rpx;
}

.progress-text {
  font-size: 16rpx;
  color: #fff;
  font-weight: 600;
}

/* 权重说明 */
.weight-info {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 12rpx 16rpx;
  background: #f8fafc;
  border-top: 1rpx solid #f1f5f9;
}

.weight-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 18rpx;
}

.weight-dot {
  width: 8rpx;
  height: 8rpx;
  border-radius: 4rpx;
}

.weight-item.weight-blue .weight-dot {
  background: #3b82f6;
}

.weight-item.weight-orange .weight-dot {
  background: #f97316;
}

.weight-item.weight-purple .weight-dot {
  background: #a855f7;
}

.weight-label {
  color: #4b5563;
  font-weight: 500;
}

.weight-desc {
  color: #9ca3af;
}

/* 总结卡片 */
.summary-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
  margin: 0 16rpx 16rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.summary-icon {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #fbbf24, #f59e0b);
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.summary-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
  display: block;
}

.summary-subtitle {
  font-size: 18rpx;
  color: #6b7280;
  display: block;
}

/* 四个功能卡片 */
.feature-cards {
  padding: 16rpx;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.feature-card {
  background: #fff;
  border-radius: 12rpx;
  padding: 20rpx 16rpx;
  text-align: center;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f3f4f6;
  transition: all 0.3s;
}

.feature-card:active {
  transform: scale(0.98);
  box-shadow: 0 1rpx 6rpx rgba(0, 0, 0, 0.08);
}

.feature-icon {
  width: 48rpx;
  height: 48rpx;
  margin: 0 auto 12rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.feature-card:nth-child(1) .feature-icon {
  background: linear-gradient(135deg, #eff6ff, #dbeafe);
}

.feature-card:nth-child(2) .feature-icon {
  background: linear-gradient(135deg, #f0fdf4, #dcfce7);
}

.feature-card:nth-child(3) .feature-icon {
  background: linear-gradient(135deg, #fff7ed, #ffedd5);
}

.feature-card:nth-child(4) .feature-icon {
  background: linear-gradient(135deg, #faf5ff, #f3e8ff);
}

.feature-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 4rpx;
  display: block;
}

.feature-desc {
  font-size: 18rpx;
  color: #6b7280;
  display: block;
}

/* 展开详情 */
.expand-detail {
  margin-top: 12rpx;
  padding: 12rpx;
  background: #f8fafc;
  border-radius: 8rpx;
}

.expand-detail-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #475569;
  margin-bottom: 8rpx;
}

.expand-detail-content {
  font-size: 18rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 按钮样式 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
  padding: 12rpx 20rpx;
  border: none;
  transition: all 0.2s;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: #fff;
}

.btn-primary:active {
  background: linear-gradient(135deg, #2563eb, #1d4ed8);
}

.btn-outline {
  background: transparent;
  color: #10b981;
  border: 1rpx solid #10b981;
}

.btn-outline:active {
  background: #f0fdf4;
}

.btn-sm {
  padding: 10rpx 16rpx;
  font-size: 22rpx;
}

.arrow {
  margin-left: 4rpx;
}

/* 入口卡片 */
.entry-card {
  background: #fff;
  border-radius: 12rpx;
  margin: 0 16rpx 12rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  gap: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 1rpx solid #f3f4f6;
}

.entry-card:active {
  background: #f9fafb;
}

.entry-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
}

.entry-content {
  flex: 1;
}

.entry-title {
  font-size: 24rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
}

.entry-desc {
  font-size: 18rpx;
  color: #6b7280;
  display: block;
  margin-top: 2rpx;
}

.entry-arrow {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 提示卡片 */
.tip-card {
  background: linear-gradient(135deg, #fef3c7, #fef9c3);
  border-radius: 12rpx;
  margin: 0 16rpx 16rpx;
  padding: 16rpx 20rpx;
  border: 1rpx solid #fcd34d;
}

.tip-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.tip-text {
  font-size: 20rpx;
  color: #92400e;
  line-height: 1.5;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  text-align: center;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.empty-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

/* 欢迎区域 */
.welcome-section {
  padding: 20rpx 16rpx;
}

.welcome-card {
  background: linear-gradient(135deg, #10b981, #059669);
  border-radius: 16rpx;
  padding: 24rpx;
  color: #fff;
  text-align: center;
}

.welcome-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.welcome-desc {
  font-size: 20rpx;
  opacity: 0.9;
  margin-bottom: 20rpx;
}

.welcome-btn {
  background: rgba(255, 255, 255, 0.2);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
  padding: 12rpx 32rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 功能网格 */
.function-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 8rpx;
  padding: 0 16rpx;
  margin-top: 16rpx;
}

.function-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 8rpx;
  background: #fff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.function-item:active {
  background: #f9fafb;
}

.function-icon {
  font-size: 32rpx;
  margin-bottom: 8rpx;
}

.function-name {
  font-size: 18rpx;
  color: #4b5563;
  text-align: center;
}

/* 版本信息 */
.version-info {
  text-align: center;
  padding: 20rpx;
  color: #9ca3af;
  font-size: 18rpx;
}
