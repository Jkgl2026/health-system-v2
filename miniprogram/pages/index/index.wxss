/* pages/index/index.wxss */

.container {
  min-height: 100vh;
  padding: 24rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #ffffff 50%, #f0fdf4 100%);
}

/* 加载状态 */
.loading {
  display: flex;
  justify-content: center;
  align-items: center;
  height: 80vh;
  color: #6b7280;
}

/* 健康数据概览 */
.health-overview {
  padding-bottom: 120rpx;
}

/* 卡片 */
.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

/* 评分卡片 */
.score-card {
  border: 4rpx solid #e0e7ff;
}

.score-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
}

.score-icon {
  width: 80rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #6366f1 0%, #4f46e5 100%);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.icon-text {
  font-size: 40rpx;
}

.score-title {
  flex: 1;
}

.title-main {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
}

.title-sub {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
  display: block;
}

/* 主评分 */
.score-main {
  text-align: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.score-value {
  display: flex;
  align-items: baseline;
  justify-content: center;
}

.score-number {
  font-size: 80rpx;
  font-weight: 700;
  color: #ffffff;
}

.score-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  margin-left: 8rpx;
}

.score-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
  display: block;
}

.score-bar {
  height: 16rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 8rpx;
  margin-top: 20rpx;
  overflow: hidden;
}

.score-fill {
  height: 100%;
  background: #ffffff;
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

/* 详情卡片 */
.score-details {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.detail-item {
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f9fafb;
}

.detail-item.blue {
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
}

.detail-item.orange {
  background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%);
  color: #ffffff;
}

.detail-item.purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
  color: #ffffff;
}

.detail-item.red {
  background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
  color: #ffffff;
}

.detail-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 8rpx;
}

.detail-label {
  font-size: 24rpx;
  opacity: 0.9;
}

.detail-icon {
  font-size: 20rpx;
  opacity: 0.7;
}

.detail-value {
  margin-bottom: 8rpx;
}

.value-num {
  font-size: 36rpx;
  font-weight: 700;
}

.value-total {
  font-size: 20rpx;
  opacity: 0.8;
}

.detail-bar {
  height: 8rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 4rpx;
  overflow: hidden;
}

.bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s ease;
}

.bar-fill.blue {
  background: #ffffff;
}

.bar-fill.orange {
  background: #ffffff;
}

.bar-fill.purple {
  background: #ffffff;
}

/* 展开详情 */
.detail-expand {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.2);
}

.expand-title {
  font-size: 22rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}

.tag-list {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.tag {
  padding: 6rpx 12rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 6rpx;
  font-size: 20rpx;
}

.tag.important {
  background: rgba(255, 255, 255, 0.3);
  font-weight: 500;
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

/* 快捷入口 */
.quick-actions {
  margin-top: 24rpx;
}

.action-card {
  background: linear-gradient(135deg, #f0fdf4 0%, #dcfce7 100%);
  border: 2rpx solid #86efac;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-bottom: 16rpx;
}

.action-icon.green {
  background: linear-gradient(135deg, #10b981 0%, #059669 100%);
}

.action-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.action-desc {
  font-size: 24rpx;
  color: #6b7280;
}

/* 欢迎页面 */
.welcome {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 24rpx;
}

/* Logo区域 */
.logo-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 48rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #10b981 100%);
  border-radius: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.logo-icon {
  font-size: 60rpx;
}

.app-name {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.app-slogan {
  font-size: 28rpx;
  color: #6b7280;
}

/* 功能介绍 */
.features {
  width: 100%;
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.feature-item {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.feature-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.feature-icon.blue {
  background: #dbeafe;
}

.feature-icon.green {
  background: #d1fae5;
}

.feature-icon.purple {
  background: #ede9fe;
}

.feature-icon.orange {
  background: #fef3c7;
}

.feature-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.feature-desc {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.4;
}

/* 步骤 */
.steps {
  width: 100%;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.steps-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 24rpx;
  display: block;
}

.step-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.step-item {
  display: flex;
  align-items: center;
}

.step-num {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  color: #ffffff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  margin-right: 20rpx;
}

.step-text {
  font-size: 28rpx;
  color: #374151;
}

/* 开始按钮 */
.start-area {
  width: 100%;
  padding: 0 24rpx;
}

.start-btn {
  margin-bottom: 16rpx;
}

.demo-btn {
  background: #ffffff;
  color: #8b5cf6;
  border: 2rpx solid #8b5cf6;
}
.demo-btn {
  background: #ffffff;
  color: #8b5cf6;
  border: 2rpx solid #8b5cf6;
}

/* 底部导航 */
.bottom-nav {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0, 0, 0, 0.05);
  padding: 16rpx 0;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.nav-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.nav-icon {
  font-size: 40rpx;
  margin-bottom: 4rpx;
}

.nav-text {
  font-size: 22rpx;
  color: #6b7280;
}

.nav-item.active .nav-text {
  color: #3b82f6;
  font-weight: 600;
}
