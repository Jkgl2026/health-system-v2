/* pages/index/index.wxss */
/* 首页样式 - 简洁版 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f0fdf4 0%, #ffffff 50%, #eff6ff 100%);
  padding-bottom: 100rpx;
}

/* 头部 */
.header {
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 100;
  padding: 20rpx 24rpx;
}

.header-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.logo-section {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.logo {
  width: 60rpx;
  height: 60rpx;
  background: linear-gradient(135deg, #10b981, #3b82f6);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.logo-icon {
  font-size: 32rpx;
}

.header-text {
  display: flex;
  flex-direction: column;
}

.header-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.header-subtitle {
  font-size: 22rpx;
  color: #6b7280;
}

/* 按钮 */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 12rpx;
  font-size: 26rpx;
  font-weight: 500;
  padding: 16rpx 28rpx;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #10b981, #059669);
  color: #fff;
}

.btn-primary:active {
  opacity: 0.9;
}

.btn-outline {
  background: transparent;
  color: #10b981;
  border: 1rpx solid #10b981;
}

.btn-sm {
  padding: 12rpx 20rpx;
  font-size: 24rpx;
}

.btn-lg {
  padding: 24rpx 40rpx;
  font-size: 32rpx;
}

.btn-block {
  width: 100%;
}

/* 页面切换 */
.page-switch {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: rgba(16, 185, 129, 0.08);
  margin: 16rpx;
  border-radius: 12rpx;
}

.page-indicator {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.page-num {
  width: 36rpx;
  height: 36rpx;
  background: #10b981;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 700;
  font-size: 22rpx;
}

.page-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #065f46;
}

/* 健康数据概览 */
.health-overview {
  padding: 8rpx 16rpx;
}

/* 健康数据卡片 */
.health-card {
  background: white;
  border-radius: 16rpx;
  margin: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  overflow: hidden;
}

.card-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #eff6ff 0%, #f0f9ff 100%);
  border-bottom: 1rpx solid #e5e7eb;
}

.card-title-section {
  display: flex;
  align-items: center;
  flex: 1;
}

.card-icon {
  width: 48rpx;
  height: 48rpx;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.card-title-text {
  display: flex;
  flex-direction: column;
}

.card-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.card-desc {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

/* 健康评分 */
.score-section {
  padding: 24rpx 16rpx;
}

.score-main {
  background: linear-gradient(135deg, #10b981, #059669);
  border-radius: 20rpx;
  padding: 32rpx;
  text-align: center;
  color: #fff;
}

.score-label {
  font-size: 24rpx;
  opacity: 0.9;
  display: block;
  margin-bottom: 8rpx;
}

.score-value {
  font-size: 72rpx;
  font-weight: 700;
  display: block;
}

.score-unit {
  font-size: 22rpx;
  opacity: 0.8;
  display: block;
  margin-top: 4rpx;
}

/* 统计卡片网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  padding: 8rpx 16rpx;
}

.stat-card {
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  padding: 20rpx 16rpx;
  position: relative;
}

.stat-label {
  font-size: 22rpx;
  font-weight: 500;
  color: #4b5563;
  display: block;
  margin-bottom: 8rpx;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  display: inline;
}

.stat-unit {
  font-size: 20rpx;
  color: #6b7280;
  margin-left: 4rpx;
}

.stat-card.stat-blue .stat-value {
  color: #3b82f6;
}

.stat-card.stat-orange .stat-value {
  color: #f97316;
}

.stat-card.stat-purple .stat-value {
  color: #a855f7;
}

.stat-card.stat-red .stat-value {
  color: #ef4444;
}

.progress-bar {
  height: 6rpx;
  background: #e5e7eb;
  border-radius: 3rpx;
  margin-top: 12rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #10b981, #3b82f6);
  border-radius: 3rpx;
}

.stat-card.stat-blue .progress-fill {
  background: #3b82f6;
}

.stat-card.stat-orange .progress-fill {
  background: #f97316;
}

.stat-card.stat-purple .progress-fill {
  background: #a855f7;
}

.stat-card.stat-red .progress-fill {
  background: #ef4444;
}

/* 展开内容 */
.expanded-content {
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.tag {
  font-size: 18rpx;
  padding: 4rpx 10rpx;
  background: #f3f4f6;
  border-radius: 6rpx;
  color: #4b5563;
}

.tag-important {
  background: #fef2f2;
  color: #dc2626;
}

/* 报告区域 */
.report-section {
  padding: 20rpx 16rpx;
}

.report-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.report-text {
  font-size: 24rpx;
  color: #4b5563;
  line-height: 1.7;
  display: block;
}

.highlight {
  font-weight: 600;
  color: #10b981;
}

/* 推荐调理 */
.recommend-section {
  padding: 16rpx;
}

.recommend-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 12rpx;
}

.recommend-list {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.recommend-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
  padding: 14rpx 16rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
}

.recommend-name {
  font-size: 24rpx;
  font-weight: 500;
  color: #1f2937;
}

.recommend-desc {
  font-size: 20rpx;
  color: #6b7280;
}

/* 操作区域 */
.action-section {
  padding: 24rpx 16rpx;
}

/* 主内容区域 */
.main-content {
  padding: 8rpx 0;
}

/* 欢迎区域 */
.welcome-section {
  padding: 32rpx 20rpx;
  text-align: center;
}

.welcome-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
  line-height: 1.5;
  display: block;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
  display: block;
}

/* 问题区域 */
.questions-section {
  padding: 16rpx 20rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
  display: block;
  margin-bottom: 16rpx;
}

.question-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 16rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
}

.question-num {
  width: 32rpx;
  height: 32rpx;
  background: #10b981;
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.question-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.5;
}

/* 功能特点 */
.features-section {
  padding: 16rpx 20rpx;
}

.features-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.feature-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  padding: 20rpx 12rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
}

.feature-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.feature-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.feature-desc {
  font-size: 20rpx;
  color: #6b7280;
}

/* 步骤 */
.steps-section {
  padding: 16rpx 20rpx;
}

.steps-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.step-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.5);
  border-radius: 12rpx;
}

.step-icon {
  font-size: 28rpx;
  flex-shrink: 0;
}

.step-content {
  flex: 1;
}

.step-title {
  font-size: 24rpx;
  font-weight: 500;
  color: #1f2937;
  display: block;
}

.step-desc {
  font-size: 20rpx;
  color: #6b7280;
  display: block;
  margin-top: 4rpx;
}

/* 开始按钮 */
.start-section {
  padding: 32rpx 20rpx;
}

/* 次要按钮 */
.btn-secondary {
  background: white;
  color: #3b82f6;
  border: 2rpx solid #3b82f6;
  margin-top: 16rpx;
}

.btn-secondary:active {
  background: #eff6ff;
}
