<!--pages/index/index.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{isLoading}}" class="loading">
    <text>加载中...</text>
  </view>

  <!-- 有健康数据时显示 -->
  <view wx:elif="{{hasHealthData && healthData}}" class="health-overview">
    <!-- 健康评分卡片 -->
    <view class="card score-card">
      <view class="score-header">
        <view class="score-icon">
          <text class="icon-text">📊</text>
        </view>
        <view class="score-title">
          <text class="title-main">您的健康数据概览</text>
          <text class="title-sub">基于上次自检的综合分析报告</text>
        </view>
      </view>

      <view class="score-main">
        <view class="score-value">
          <text class="score-number">{{healthData.healthScore}}</text>
          <text class="score-unit">分</text>
        </view>
        <text class="score-label">健康评分（满分100）</text>
        <view class="score-bar">
          <view class="score-fill" style="width: {{healthData.healthScore}}%"></view>
        </view>
      </view>

      <view class="score-details">
        <view class="detail-item blue" bindtap="toggleCard" data-card="bodySymptoms">
          <view class="detail-header">
            <text class="detail-label">身体语言简表</text>
            <text class="detail-icon">{{expandedCard === 'bodySymptoms' ? '▼' : '▶'}}</text>
          </view>
          <view class="detail-value">
            <text class="value-num">{{healthData.bodySymptomsCount}}</text>
            <text class="value-total">/ 100项</text>
          </view>
          <view class="detail-bar">
            <view class="bar-fill blue" style="width: {{healthData.bodySymptomsCount}}%"></view>
          </view>
        </view>

        <view class="detail-item orange" bindtap="toggleCard" data-card="badHabits">
          <view class="detail-header">
            <text class="detail-label">不良生活习惯</text>
            <text class="detail-icon">{{expandedCard === 'badHabits' ? '▼' : '▶'}}</text>
          </view>
          <view class="detail-value">
            <text class="value-num">{{healthData.badHabitsCount}}</text>
            <text class="value-total">/ 252项</text>
          </view>
          <view class="detail-bar">
            <view class="bar-fill orange" style="width: {{healthData.badHabitsCount * 100 / 252}}%"></view>
          </view>
        </view>

        <view class="detail-item purple" bindtap="toggleCard" data-card="symptoms300">
          <view class="detail-header">
            <text class="detail-label">300症状表</text>
            <text class="detail-icon">{{expandedCard === 'symptoms300' ? '▼' : '▶'}}</text>
          </view>
          <view class="detail-value">
            <text class="value-num">{{healthData.symptoms300Count}}</text>
            <text class="value-total">/ 300项</text>
          </view>
          <view class="detail-bar">
            <view class="bar-fill purple" style="width: {{healthData.symptoms300Count * 100 / 300}}%"></view>
          </view>
        </view>

        <view class="detail-item red" bindtap="toggleCard" data-card="targetSymptoms">
          <view class="detail-header">
            <text class="detail-label">重点症状</text>
            <text class="detail-icon">{{expandedCard === 'targetSymptoms' ? '▼' : '▶'}}</text>
          </view>
          <view class="detail-value">
            <text class="value-num">{{healthData.targetSymptomsCount}}</text>
            <text class="value-total">个（最多3个）</text>
          </view>
        </view>
      </view>

      <!-- 操作按钮 -->
      <view class="action-buttons">
        <button class="btn btn-primary" bindtap="viewSolution">
          查看完整方案
        </button>
        <button class="btn btn-secondary" bindtap="startCheck">
          重新自检
        </button>
      </view>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-actions">
      <view class="action-card" bindtap="viewHealthResult">
        <view class="action-icon green">
          <text>📈</text>
        </view>
        <text class="action-title">健康要素分析</text>
        <text class="action-desc">查看七个要素的详细分析</text>
      </view>
    </view>
  </view>

  <!-- 无健康数据时显示 -->
  <view wx:else class="welcome">
    <!-- Logo区域 -->
    <view class="logo-area">
      <view class="logo">
        <text class="logo-icon">❤️</text>
      </view>
      <text class="app-name">健康自我管理</text>
      <text class="app-slogan">把健康把握在自己手里</text>
    </view>

    <!-- 功能介绍 -->
    <view class="features">
      <view class="feature-item">
        <view class="feature-icon blue">
          <text>📋</text>
        </view>
        <text class="feature-title">症状自检</text>
        <text class="feature-desc">通过100项身体语言简表，全面了解您的健康状况</text>
      </view>

      <view class="feature-item">
        <view class="feature-icon green">
          <text>📚</text>
        </view>
        <text class="feature-title">系统解析</text>
        <text class="feature-desc">深入了解症状背后的健康要素和原因</text>
      </view>

      <view class="feature-item">
        <view class="feature-icon purple">
          <text>🔄</text>
        </view>
        <text class="feature-title">持续跟进</text>
        <text class="feature-desc">通过七问体系，持续跟踪和改善健康</text>
      </view>

      <view class="feature-item">
        <view class="feature-icon orange">
          <text>🎯</text>
        </view>
        <text class="feature-title">科学方案</text>
        <text class="feature-desc">基于科学原理，提供个性化的健康管理方案</text>
      </view>
    </view>

    <!-- 自检步骤 -->
    <view class="steps">
      <text class="steps-title">自检流程</text>
      <view class="step-list">
        <view class="step-item">
          <view class="step-num">1</view>
          <text class="step-text">填简表 - 勾选半年内出现的症状</text>
        </view>
        <view class="step-item">
          <view class="step-num">2</view>
          <text class="step-text">针对症状 - 深入分析最困扰的症状</text>
        </view>
        <view class="step-item">
          <view class="step-num">3</view>
          <text class="step-text">了解原理 - 学习健康要素的科学原理</text>
        </view>
        <view class="step-item">
          <view class="step-num">4</view>
          <text class="step-text">获得方案 - 获得个性化的健康管理方案</text>
        </view>
      </view>
    </view>

    <!-- 开始按钮 -->
    <view class="start-area">
      <button class="btn btn-primary btn-block start-btn" bindtap="startCheck">
        开始自检
      </button>
      <button class="btn btn-secondary btn-block demo-btn" bindtap="loadDemoData">
        演示模式
      </button>
    </view>
  </view>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <view class="nav-item active" bindtap="goHome">
      <text class="nav-icon">🏠</text>
      <text class="nav-text">首页</text>
    </view>
    <view class="nav-item" bindtap="goSolution">
      <text class="nav-icon">📋</text>
      <text class="nav-text">我的方案</text>
    </view>
    <view class="nav-item" bindtap="goAdmin">
      <text class="nav-icon">⚙️</text>
      <text class="nav-text">后台</text>
    </view>
  </view>
</view>
