<!--pages/index/index.wxml-->
<!--首页 - 简洁版-->

<view class="container">
  <!-- 头部区域 -->
  <view class="header">
    <view class="header-content">
      <view class="logo-section">
        <view class="logo">
          <text class="logo-icon">❤️</text>
        </view>
        <view class="header-text">
          <text class="header-title">健康自我管理</text>
          <text class="header-subtitle">把健康把握在自己手里</text>
        </view>
      </view>
      <button class="btn btn-primary" bindtap="goToPersonalInfo">开始自检</button>
    </view>
  </view>

  <!-- 健康数据概览（有数据时显示） -->
  <view wx:if="{{hasHealthData && currentPage === 1}}" class="health-overview">
    <!-- 健康数据卡片标题 -->
    <view class="health-card">
      <view class="card-header">
        <view class="card-title-section">
          <view class="card-icon">📊</view>
          <view class="card-title-text">
            <view class="card-title">您的健康数据概览</view>
            <view class="card-desc">基于上次自检的综合分析报告</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 页面切换提示 -->
    <view class="page-switch">
      <view class="page-indicator">
        <view class="page-num">1</view>
        <text class="page-label">健康评分</text>
      </view>
      <button class="btn btn-primary btn-sm" bindtap="goToPage2">
        下一页 →
      </button>
    </view>

    <!-- 健康评分 -->
    <view class="score-section">
      <view class="score-main">
        <text class="score-label">健康评分</text>
        <text class="score-value">{{healthData.healthScore}}</text>
        <text class="score-unit">分</text>
      </view>
    </view>

    <!-- 统计卡片 -->
    <view class="stats-grid">
      <view class="stat-card stat-blue" bindtap="toggleCard" data-card="bodySymptoms">
        <text class="stat-label">身体语言简表</text>
        <text class="stat-value">{{healthData.bodySymptomsCount}}</text>
        <text class="stat-unit">/ 100项</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{healthData.bodySymptomsCount}}%;"></view>
        </view>
        <view wx:if="{{expandedCard === 'bodySymptoms' && healthData.bodySymptomNames.length > 0}}" class="expanded-content">
          <text wx:for="{{healthData.bodySymptomNames}}" wx:key="index" class="tag">{{item}}</text>
        </view>
      </view>

      <view class="stat-card stat-orange" bindtap="toggleCard" data-card="badHabits">
        <text class="stat-label">不良生活习惯</text>
        <text class="stat-value">{{healthData.badHabitsCount}}</text>
        <text class="stat-unit">/ 252项</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{healthData.badHabitsCount / 252 * 100}}%;"></view>
        </view>
        <view wx:if="{{expandedCard === 'badHabits' && healthData.badHabitNames.length > 0}}" class="expanded-content">
          <text wx:for="{{healthData.badHabitNames}}" wx:key="index" class="tag">{{item}}</text>
        </view>
      </view>

      <view class="stat-card stat-purple" bindtap="toggleCard" data-card="symptoms300">
        <text class="stat-label">300症状表</text>
        <text class="stat-value">{{healthData.symptoms300Count}}</text>
        <text class="stat-unit">/ 300项</text>
        <view class="progress-bar">
          <view class="progress-fill" style="width: {{healthData.symptoms300Count / 300 * 100}}%;"></view>
        </view>
        <view wx:if="{{expandedCard === 'symptoms300' && healthData.symptoms300Names.length > 0}}" class="expanded-content">
          <text wx:for="{{healthData.symptoms300Names}}" wx:key="index" class="tag">{{item}}</text>
        </view>
      </view>

      <view class="stat-card stat-red" bindtap="toggleCard" data-card="targetSymptoms">
        <text class="stat-label">重点症状</text>
        <text class="stat-value">{{healthData.targetSymptoms}}</text>
        <text class="stat-unit">个需改善</text>
        <view wx:if="{{expandedCard === 'targetSymptoms' && healthData.targetSymptomNames.length > 0}}" class="expanded-content">
          <text wx:for="{{healthData.targetSymptomNames}}" wx:key="index" class="tag tag-important">{{item}}</text>
        </view>
      </view>
    </view>

    <!-- 健康分析报告 -->
    <view class="report-section">
      <text class="report-title">📊 健康分析报告</text>
      <text class="report-text">
        您共有<text class="highlight">{{healthData.totalSymptoms}}项</text>健康异常，
        综合健康评分<text class="highlight">{{healthData.healthScore}}分</text>。
        {{healthData.healthScore >= 80 ? '整体健康状况良好，继续保持。' :
          healthData.healthScore >= 60 ? '处于亚健康状态，建议及时调理。' :
          '需要重点关注，建议尽快调理。'}}
      </text>
    </view>

    <!-- 推荐调理 -->
    <view class="recommend-section">
      <text class="recommend-title">🔥 推荐调理方向</text>
      <view class="recommend-list">
        <view class="recommend-item">
          <text class="recommend-name">艾灸调理</text>
          <text class="recommend-desc">温通经络、调和气血</text>
        </view>
        <view wx:if="{{healthData.bodySymptomsCount > 5 || healthData.badHabitsCount > 10}}" class="recommend-item">
          <text class="recommend-name">火灸调理</text>
          <text class="recommend-desc">疏通经络、祛除寒湿</text>
        </view>
      </view>
    </view>

    <!-- 查看完整方案按钮 -->
    <view class="action-section">
      <button class="btn btn-primary btn-block" bindtap="goToMySolution">
        查看完整调理方案 →
      </button>
      <button class="btn btn-secondary btn-block" bindtap="goToHistoryCompare">
        📊 数据对比分析 →
      </button>
    </view>
  </view>

  <!-- 主内容区域（无数据或第二页时显示） -->
  <view wx:if="{{!hasHealthData || currentPage === 2}}" class="main-content">
    <!-- 返回按钮（有数据时显示） -->
    <view wx:if="{{hasHealthData}}" class="page-switch">
      <button class="btn btn-outline btn-sm" bindtap="goToPage1">← 返回评分</button>
      <view class="page-indicator">
        <view class="page-num">2</view>
        <text class="page-label">健康理念</text>
      </view>
    </view>

    <!-- 欢迎区域 -->
    <view class="welcome-section">
      <text class="welcome-title">让老百姓少花钱甚至不花钱解决问题</text>
      <text class="welcome-desc">健康自我管理的核心价值在于教会您健康观念，把健康把握在自己手里。</text>
    </view>

    <!-- 三个核心问题 -->
    <view class="questions-section">
      <text class="section-title">三个核心问题</text>
      <view class="question-item">
        <text class="question-num">1</text>
        <text class="question-text">老百姓是舒服的时候去医院，还是难受的时候？</text>
      </view>
      <view class="question-item">
        <text class="question-num">2</text>
        <text class="question-text">明明难受，但医院检查结论却是"正常"？</text>
      </view>
      <view class="question-item">
        <text class="question-num">3</text>
        <text class="question-text">很多人一辈子都没做过身体自检？</text>
      </view>
    </view>

    <!-- 功能特点 -->
    <view class="features-section">
      <text class="section-title">功能特点</text>
      <view class="features-grid">
        <view class="feature-item" wx:for="{{features}}" wx:key="title">
          <text class="feature-icon">{{item.icon}}</text>
          <text class="feature-title">{{item.title}}</text>
          <text class="feature-desc">{{item.description}}</text>
        </view>
      </view>
    </view>

    <!-- 自检流程 -->
    <view class="steps-section">
      <text class="section-title">自检流程</text>
      <view class="steps-list">
        <view class="step-item" wx:for="{{steps}}" wx:key="title">
          <text class="step-icon">{{item.icon}}</text>
          <view class="step-content">
            <text class="step-title">{{item.title}}</text>
            <text class="step-desc">{{item.description}}</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 开始按钮 -->
    <view class="start-section">
      <button class="btn btn-primary btn-lg btn-block" bindtap="goToPersonalInfo">
        开始健康自检
      </button>
    </view>
  </view>
</view>
