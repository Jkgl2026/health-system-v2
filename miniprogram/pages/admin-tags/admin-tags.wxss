/* pages/admin-tags/admin-tags.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  font-size: 28rpx;
  color: #3b82f6;
  padding: 12rpx 20rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.header-action {
  width: 100rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #10b981;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #64748b;
}

/* 内容区域 */
.content {
  padding: 24rpx;
}

/* 区块 */
.section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-desc {
  font-size: 24rpx;
  color: #94a3b8;
  margin-left: 16rpx;
}

.section-count {
  font-size: 24rpx;
  color: #64748b;
  margin-left: auto;
}

/* 标签云 */
.tag-cloud {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: #f8fafc;
  border-radius: 20rpx;
  border: 2rpx solid var(--tag-color, #e2e8f0);
  transition: all 0.2s;
}

.tag-item.selected {
  background: var(--tag-color, #10b981);
}

.tag-name {
  font-size: 26rpx;
  color: var(--tag-color, #64748b);
  margin-right: 8rpx;
}

.tag-item.selected .tag-name {
  color: #ffffff;
}

.tag-count {
  font-size: 22rpx;
  color: #ffffff;
  background: var(--tag-color, #64748b);
  padding: 2rpx 12rpx;
  border-radius: 10rpx;
}

.tag-item.selected .tag-count {
  background: rgba(255, 255, 255, 0.3);
}

/* 空标签 */
.empty-tags {
  padding: 40rpx;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: #94a3b8;
}

/* 用户区域 */
.user-section {
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

/* 用户列表 */
.user-list {
  
}

.user-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f1f5f9;
}

.user-item:last-child {
  border-bottom: none;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-avatar {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
}

.avatar-text {
  font-size: 28rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-detail {
  
}

.user-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #1e293b;
  display: block;
}

.user-phone {
  font-size: 24rpx;
  color: #94a3b8;
  margin-top: 4rpx;
  display: block;
}

.user-score {
  
}

.score-value {
  font-size: 28rpx;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  padding: 60rpx;
  text-align: center;
}
