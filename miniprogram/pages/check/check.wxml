<!--pages/check/check.wxml-->
<view class="container">
  <!-- 顶部提示 -->
  <view class="header">
    <view class="header-content">
      <text class="header-title">身体语言简表</text>
      <text class="header-desc">请勾选半年内出现的症状（100项）</text>
    </view>
    <view class="selected-count">
      <text class="count-num">{{selectedSymptoms.length}}</text>
      <text class="count-label">项已选</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索症状..."
      value="{{searchKeyword}}"
      bindinput="onSearch"
    />
  </view>

  <!-- 分类标签 -->
  <scroll-view wx:if="{{!isSearching}}" class="category-tabs" scroll-x enable-flex>
    <view 
      wx:for="{{categories}}" 
      wx:key="name"
      class="tab-item {{currentCategory === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onCategoryChange"
    >
      <text>{{item.name}}</text>
      <text class="tab-count">{{item.symptoms.length}}</text>
    </view>
  </scroll-view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-small btn-outline" bindtap="selectAll">全选</button>
    <button class="btn-small btn-outline" bindtap="clearCurrent">清空</button>
  </view>

  <!-- 症状列表 -->
  <scroll-view class="symptom-list" scroll-y>
    <view 
      wx:for="{{filteredSymptoms}}" 
      wx:key="id"
      class="symptom-item {{selectedSymptoms.indexOf(item.id) > -1 ? 'selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="toggleSymptom"
    >
      <view class="checkbox {{selectedSymptoms.indexOf(item.id) > -1 ? 'checked' : ''}}">
        <text wx:if="{{selectedSymptoms.indexOf(item.id) > -1}}">✓</text>
      </view>
      <view class="symptom-content">
        <text class="symptom-name">{{item.name}}</text>
        <text class="symptom-desc">{{item.description}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn btn-secondary" bindtap="onSkip">跳过</button>
    <button class="btn btn-primary" bindtap="onNext">下一步</button>
  </view>
</view>
