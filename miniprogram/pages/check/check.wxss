/* pages/check/check.wxss */
/* 身体语言简表页样式 - 1:1复刻Web版 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #dbeafe 0%, #ffffff 50%, #dcfce7 100%);
}

/* 头部 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.header-info {
  display: flex;
  align-items: center;
  gap: 8rpx;
}

.header-count {
  font-size: 26rpx;
  color: #6b7280;
}

.check-icon {
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background: #22c55e;
  color: white;
  border-radius: 50%;
  font-size: 24rpx;
}

.auto-save {
  font-size: 24rpx;
  color: #6b7280;
}

/* ========== 第一步：介绍页面 ========== */
.intro-container {
  padding: 32rpx;
}

.intro-card {
  background: white;
  border-radius: 24rpx;
  border: 4rpx solid #bfdbfe;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding: 48rpx 32rpx;
}

.intro-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.intro-title {
  display: block;
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.intro-subtitle {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #ea580c;
}

.intro-notice {
  display: flex;
  padding: 24rpx;
  background: #fef3c7;
  border-radius: 16rpx;
  border: 2rpx solid #fcd34d;
  margin-bottom: 32rpx;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.notice-text {
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.6;
}

.intro-section {
  margin-bottom: 32rpx;
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

.reason-item {
  display: flex;
  margin-bottom: 20rpx;
  align-items: flex-start;
}

.reason-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.reason-blue { background: #3b82f6; }
.reason-green { background: #22c55e; }
.reason-purple { background: #a855f7; }

.reason-content {
  flex: 1;
  padding-top: 8rpx;
}

.reason-bold {
  font-weight: 600;
  color: #111827;
}

.reason-text {
  color: #374151;
  line-height: 1.6;
}

.intro-tip {
  padding: 24rpx;
  background: #eff6ff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.tip-bold {
  font-weight: 600;
  color: #111827;
}

.tip-text {
  font-size: 26rpx;
  color: #1e40af;
  line-height: 1.6;
}

.intro-note {
  padding: 20rpx;
  background: #f3f4f6;
  border-radius: 12rpx;
  margin-bottom: 32rpx;
}

.intro-note text {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  display: block;
}

.btn-start {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

.btn-arrow {
  margin-left: 12rpx;
}

/* ========== 第二步：选择症状页面 ========== */
.select-container {
  padding: 32rpx;
  padding-bottom: 160rpx;
}

.progress-card {
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.progress-header {
  margin-bottom: 16rpx;
}

.progress-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.progress-desc {
  font-size: 26rpx;
  color: #6b7280;
}

.progress-bar-wrap {
  margin-top: 16rpx;
}

.progress-bar {
  height: 16rpx;
  background: #e5e7eb;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #3b82f6, #22c55e);
  border-radius: 8rpx;
  transition: width 0.3s;
}

.progress-label {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
}

/* 分类卡片 */
.category-card {
  background: white;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #e5e7eb;
}

.category-title-wrap {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.category-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.badge-green {
  background: #dcfce7;
  color: #16a34a;
}

.badge-gray {
  background: #f3f4f6;
  color: #6b7280;
}

.category-actions {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.action-outline {
  background: white;
  border: 1rpx solid #d1d5db;
  color: #374151;
}

.action-ghost {
  background: transparent;
  color: #6b7280;
}

/* 症状网格 */
.symptom-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 16rpx;
  gap: 12rpx;
}

.symptom-item {
  width: calc(50% - 6rpx);
  padding: 20rpx;
  border-radius: 12rpx;
  border: 3rpx solid #e5e7eb;
  background: white;
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  transition: all 0.2s;
}

.symptom-item.selected {
  border-color: #3b82f6;
  background: #eff6ff;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-top: 4rpx;
}

.checkbox.checked {
  background: #3b82f6;
  border-color: #3b82f6;
}

.checkbox-icon {
  color: white;
  font-size: 24rpx;
  font-weight: 600;
}

.symptom-info {
  flex: 1;
  min-width: 0;
}

.symptom-name {
  display: block;
  font-size: 26rpx;
  font-weight: 500;
  color: #111827;
  line-height: 1.4;
}

.symptom-desc {
  display: block;
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 6rpx;
}

/* 继续按钮 */
.continue-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  display: flex;
  justify-content: center;
}

.btn-continue {
  padding: 28rpx 64rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* ========== 第三步：确认页面 ========== */
.confirm-container {
  padding: 32rpx;
}

.confirm-card {
  background: white;
  border-radius: 24rpx;
  border: 4rpx solid #bbf7d0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  padding: 48rpx 32rpx;
}

.confirm-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.confirm-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 12rpx;
}

.confirm-desc {
  font-size: 28rpx;
  color: #6b7280;
}

.confirm-notice {
  display: flex;
  padding: 24rpx;
  background: #fef3c7;
  border-radius: 16rpx;
  border: 2rpx solid #fcd34d;
  margin-bottom: 32rpx;
}

.selected-section {
  margin-bottom: 32rpx;
}

.selected-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

.selected-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-item {
  padding: 20rpx 24rpx;
  border-radius: 12rpx;
  border: 3rpx solid #e5e7eb;
  background: white;
  text-align: center;
  position: relative;
  min-width: 140rpx;
}

.selected-item.target-selected {
  border-color: #22c55e;
  background: #dcfce7;
  box-shadow: 0 0 0 4rpx rgba(34, 197, 94, 0.3);
}

.selected-item.disabled {
  opacity: 0.5;
}

.selected-name {
  font-size: 26rpx;
  color: #111827;
}

.selected-check {
  display: block;
  margin-top: 8rpx;
  color: #22c55e;
  font-size: 28rpx;
}

/* 已选择重点改善的症状 */
.target-section {
  padding: 32rpx;
  background: #dcfce7;
  border-radius: 16rpx;
  border: 4rpx solid #86efac;
  margin-bottom: 32rpx;
}

.target-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.target-list {
  margin-bottom: 16rpx;
}

.target-item {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #15803d;
  margin-bottom: 12rpx;
}

.target-note {
  font-size: 24rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 错误提示 */
.error-section {
  padding: 24rpx;
  background: #fef2f2;
  border-radius: 12rpx;
  border: 2rpx solid #fecaca;
  margin-bottom: 24rpx;
}

.error-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.error-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #dc2626;
}

.error-message {
  font-size: 24rpx;
  color: #7f1d1d;
  margin-bottom: 16rpx;
  display: block;
}

.btn-retry {
  padding: 16rpx 32rpx;
  background: #dc2626;
  color: white;
  font-size: 26rpx;
  border-radius: 8rpx;
  border: none;
}

/* 开始分析按钮 */
.btn-analyze {
  width: 100%;
  padding: 32rpx;
  background: linear-gradient(135deg, #22c55e, #3b82f6);
  color: white;
  font-size: 34rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
}
