/* pages/check/check.wxss */
/* 身体语言简表页样式 */

.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 头部 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  font-size: 32rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1f2937;
}

.progress-info {
  background: #10b981;
  color: #fff;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

/* 进度条 */
.progress-bar-container {
  padding: 16rpx 32rpx;
  background: #fff;
}

.progress-bar {
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #10b981, #3b82f6);
  border-radius: 4rpx;
  transition: width 0.3s;
}

/* 搜索 */
.search-section {
  padding: 16rpx 24rpx;
  background: #fff;
}

.search-bar {
  display: flex;
  align-items: center;
  background: #f3f4f6;
  border-radius: 24rpx;
  padding: 16rpx 24rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.clear-btn {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 8rpx;
}

/* 分类标签 */
.category-scroll {
  background: #fff;
  white-space: nowrap;
  border-bottom: 1rpx solid #e5e7eb;
}

.category-list {
  display: inline-flex;
  padding: 16rpx 24rpx;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 24rpx;
  background: #f3f4f6;
  border-radius: 20rpx;
  font-size: 26rpx;
  color: #6b7280;
  flex-shrink: 0;
}

.category-item.active {
  background: #10b981;
  color: #fff;
}

/* 提示 */
.tip-section {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 24rpx;
  background: #fef3c7;
  margin: 16rpx 24rpx;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 28rpx;
}

.tip-text {
  font-size: 24rpx;
  color: #92400e;
}

/* 症状列表 */
.symptom-list {
  flex: 1;
  padding: 16rpx 24rpx;
  background: #fff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  max-height: 600rpx;
}

.symptom-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f3f4f6;
}

.symptom-item:last-child {
  border-bottom: none;
}

.symptom-checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  transition: all 0.2s;
}

.symptom-checkbox.checked {
  background: #10b981;
  border-color: #10b981;
}

.checkbox-icon {
  color: #fff;
  font-size: 24rpx;
  font-weight: 700;
}

.symptom-content {
  flex: 1;
}

.symptom-name {
  display: block;
  font-size: 28rpx;
  color: #1f2937;
  margin-bottom: 4rpx;
}

.symptom-category {
  display: block;
  font-size: 22rpx;
  color: #9ca3af;
}

/* 已选统计 */
.selected-summary {
  margin: 16rpx 24rpx;
  padding: 20rpx;
  background: #fff;
  border-radius: 16rpx;
}

.summary-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.summary-icon {
  font-size: 28rpx;
}

.summary-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.selected-tags {
  white-space: nowrap;
}

.tag-list {
  display: inline-flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.selected-tag {
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 16rpx;
  background: #ecfdf5;
  border: 1rpx solid #10b981;
  border-radius: 20rpx;
}

.tag-name {
  font-size: 24rpx;
  color: #10b981;
}

.tag-remove {
  font-size: 20rpx;
  color: #10b981;
  padding: 4rpx;
}

.empty-tip {
  text-align: center;
  padding: 16rpx;
  color: #9ca3af;
  font-size: 24rpx;
}

/* 底部按钮 */
.bottom-actions {
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #fff;
  border-top: 1rpx solid #e5e7eb;
}

.btn {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-primary {
  background: linear-gradient(90deg, #3b82f6, #10b981);
  color: #fff;
}

.btn-outline {
  background: #fff;
  border: 2rpx solid #e5e7eb;
  color: #6b7280;
}

.btn-arrow {
  margin-left: 8rpx;
}
