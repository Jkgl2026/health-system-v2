/* pages/choices/choices.wxss */
/* 三个选择，四个要求页面样式 - Web版精确复刻 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #eff6ff 0%, #ffffff 50%, #f0fdf4 100%);
  padding-bottom: 120rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-badge {
  padding: 8rpx 24rpx;
  border: 2rpx solid #d1d5db;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #374151;
}

/* 开场说明 */
.intro-card {
  margin: 32rpx;
  padding: 40rpx;
  background: white;
  border-radius: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.intro-title {
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.intro-desc {
  text-align: center;
  font-size: 30rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.intro-alert {
  display: flex;
  padding: 24rpx;
  background: #fef3c7;
  border-radius: 16rpx;
  border: 2rpx solid #fcd34d;
}

.alert-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
}

.alert-text {
  font-size: 28rpx;
  color: #92400e;
  line-height: 1.6;
}

/* 标题 */
.section-title {
  font-size: 36rpx;
  font-weight: 700;
  text-align: center;
  color: #111827;
  margin: 48rpx 0 32rpx;
}

/* 选择卡片 */
.choice-card {
  margin: 0 32rpx 24rpx;
  padding: 32rpx;
  background: white;
  border-radius: 20rpx;
  border: 4rpx solid #e5e7eb;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.choice-card.selected {
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.1);
}

.choice-card.choice1-selected {
  border-color: #3b82f6;
  background: linear-gradient(135deg, #eff6ff, white);
}

.choice-card.choice2-selected {
  border-color: #22c55e;
  background: linear-gradient(135deg, #f0fdf4, white);
}

.choice-card.choice3-selected {
  border-color: #a855f7;
  background: linear-gradient(135deg, #faf5ff, white);
}

.choice-header {
  display: flex;
  align-items: flex-start;
}

.choice-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.choice1-icon {
  background: #dbeafe;
}

.choice2-icon {
  background: #dcfce7;
}

.choice3-icon {
  background: #f3e8ff;
}

.choice-info {
  flex: 1;
}

.choice-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.choice-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
}

.choice-check {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #22c55e;
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 600;
}

/* 展开详情 */
.choice-details {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 2rpx solid #e5e7eb;
}

.details-section {
  padding: 24rpx;
  background: #f8fafc;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.details-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.detail-item {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  margin-bottom: 12rpx;
}

.requirements-section {
  padding: 24rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
}

.requirements-section.warning {
  background: #fffbeb;
  border-color: #fcd34d;
}

.requirements-section.danger {
  background: #fef2f2;
  border-color: #fca5a5;
}

.requirements-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.requirement-item {
  font-size: 26rpx;
  color: #92400e;
  line-height: 1.6;
}

/* 选择说明 */
.choice-alert {
  margin: 24rpx 32rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  border: 4rpx solid;
}

.choice-alert.choice1 {
  background: #eff6ff;
  border-color: #3b82f6;
}

.choice-alert.choice2 {
  background: #f0fdf4;
  border-color: #22c55e;
}

.choice-alert.choice3 {
  background: #faf5ff;
  border-color: #a855f7;
}

.alert-content {
  font-size: 28rpx;
  line-height: 1.8;
}

.choice-alert.choice1 .alert-content {
  color: #1e40af;
}

.choice-alert.choice2 .alert-content {
  color: #166534;
}

.choice-alert.choice3 .alert-content {
  color: #7c3aed;
}

/* 四个要求区域 */
.requirements-section-container {
  margin-top: 24rpx;
}

.requirements-intro {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
}

.intro-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.intro-text {
  font-size: 28rpx;
  color: #374151;
}

/* 要求卡片 */
.requirement-card {
  margin: 0 32rpx 20rpx;
  padding: 32rpx;
  background: white;
  border-radius: 16rpx;
  border: 4rpx solid #e5e7eb;
  transition: all 0.3s ease;
}

.requirement-card.accepted {
  border-width: 4rpx;
}

.requirement-card.req1-accepted {
  border-color: #3b82f6;
  background: #eff6ff;
}

.requirement-card.req2-accepted {
  border-color: #22c55e;
  background: #f0fdf4;
}

.requirement-card.req3-accepted {
  border-color: #a855f7;
  background: #faf5ff;
}

.requirement-card.req4-accepted {
  border-color: #f97316;
  background: #fff7ed;
}

.req-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.req-checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 28rpx;
  color: white;
  background: white;
  transition: all 0.2s ease;
}

.requirement-card.accepted .req-checkbox {
  background: #22c55e;
  border-color: #22c55e;
}

.req-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 16rpx;
}

.req1-icon {
  background: linear-gradient(135deg, #3b82f6, #22c55e);
}

.req2-icon {
  background: linear-gradient(135deg, #22c55e, #3b82f6);
}

.req3-icon {
  background: linear-gradient(135deg, #a855f7, #ec4899);
}

.req4-icon {
  background: linear-gradient(135deg, #f97316, #ef4444);
}

.req-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.req-content {
  margin-top: 12rpx;
}

.req-desc {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 16rpx;
}

.req-details-box {
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
}

.req-details-box.blue {
  background: #eff6ff;
  border-color: #93c5fd;
}

.req-details-box.green {
  background: #f0fdf4;
  border-color: #86efac;
}

.req-details-box.purple {
  background: #faf5ff;
  border-color: #d8b4fe;
}

.req-details-box.orange {
  background: #fff7ed;
  border-color: #fdba74;
}

.box-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.box-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.box-warning {
  font-size: 24rpx;
  color: #dc2626;
  font-weight: 600;
}

.box-benefit {
  font-size: 24rpx;
  color: #16a34a;
}

.box-benefit.orange {
  color: #ea580c;
}

.box-reason {
  font-size: 24rpx;
  color: #374151;
  margin-bottom: 8rpx;
}

.box-item {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.8;
}

/* 四个要求提示 */
.requirements-notice {
  margin: 24rpx 32rpx;
  padding: 24rpx;
  background: #faf5ff;
  border: 4rpx solid #a855f7;
  border-radius: 16rpx;
  display: flex;
}

.notice-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #7c3aed;
  line-height: 1.6;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: white;
  border-top: 2rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}

.btn-primary.disabled {
  background: #9ca3af;
}

.action-tip {
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 16rpx;
}
