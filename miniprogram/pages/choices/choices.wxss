/* pages/choices/choices.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
}

.progress-bar {
  position: relative;
  height: 80rpx;
  background: #e0e0e0;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #4CAF50, #8BC34A);
  transition: width 0.3s;
}

.progress-steps {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 0 50rpx;
}

.step {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  transition: all 0.3s;
}

.step.active {
  background: #4CAF50;
  color: white;
}

.step.done {
  background: #8BC34A;
  color: white;
}

.step-num {
  font-size: 24rpx;
  font-weight: bold;
}

.choice-swiper {
  flex: 1;
  height: calc(100vh - 200rpx);
}

.choice-card {
  padding: 30rpx;
  box-sizing: border-box;
}

.choice-header {
  text-align: center;
  margin-bottom: 40rpx;
}

.choice-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.choice-question {
  display: block;
  font-size: 30rpx;
  color: #666;
  line-height: 1.5;
}

.options {
  margin-bottom: 30rpx;
}

.option {
  display: flex;
  align-items: center;
  background: white;
  padding: 30rpx;
  margin-bottom: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
  transition: all 0.3s;
}

.option.selected {
  border: 3rpx solid #4CAF50;
  background: #f1f8e9;
}

.option-radio {
  width: 44rpx;
  height: 44rpx;
  border: 3rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: white;
  transition: all 0.3s;
}

.option.selected .option-radio {
  background: #4CAF50;
  border-color: #4CAF50;
}

.option-content {
  flex: 1;
}

.option-label {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
  font-weight: 500;
}

.option-desc {
  display: block;
  font-size: 24rpx;
  color: #999;
}

.choice-note {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #e3f2fd;
  border-radius: 12rpx;
  margin-top: 20rpx;
}

.note-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.note-text {
  font-size: 24rpx;
  color: #1976D2;
  line-height: 1.5;
}

.bottom-nav {
  display: flex;
  justify-content: space-between;
  padding: 20rpx 30rpx;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.nav-btn {
  min-width: 200rpx;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: bold;
}

.nav-btn.prev {
  background: #f5f5f5;
  color: #666;
}

.nav-btn.next {
  background: #f5f5f5;
  color: #666;
}

.nav-btn.next.primary {
  background: linear-gradient(135deg, #4CAF50, #8BC34A);
  color: white;
}

.nav-placeholder {
  min-width: 200rpx;
}
