/* pages/choices/choices.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; background: #fff; }
.header-title { font-size: 32rpx; font-weight: 600; }
.intro-section { padding: 32rpx; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; text-align: center; }
.intro-title { display: block; font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.intro-desc { display: block; font-size: 24rpx; opacity: 0.9; }
.choices-list { padding: 24rpx; }
.choice-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.choice-header { display: flex; align-items: center; gap: 16rpx; margin-bottom: 16rpx; }
.choice-num { width: 48rpx; height: 48rpx; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 24rpx; }
.choice-title { font-size: 28rpx; font-weight: 600; color: #1f2937; }
.choice-question { display: block; font-size: 26rpx; color: #6b7280; margin-bottom: 20rpx; line-height: 1.5; }
.options-list { display: flex; flex-direction: column; gap: 16rpx; }
.option-item { display: flex; align-items: flex-start; gap: 16rpx; padding: 20rpx; background: #f9fafb; border-radius: 12rpx; border: 2rpx solid #e5e7eb; }
.option-item.selected { background: #eef2ff; border-color: #6366f1; }
.option-radio { font-size: 32rpx; color: #6366f1; }
.option-content { flex: 1; }
.option-label { display: block; font-size: 28rpx; font-weight: 500; color: #1f2937; margin-bottom: 4rpx; }
.option-desc { display: block; font-size: 22rpx; color: #6b7280; }
.bottom-actions { display: flex; gap: 16rpx; padding: 24rpx; background: #fff; position: fixed; bottom: 0; left: 0; right: 0; }
.btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-primary[disabled] { opacity: 0.5; }
.btn-outline { background: #fff; border: 2rpx solid #e5e7eb; color: #6b7280; }
