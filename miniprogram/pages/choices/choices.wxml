<!--pages/choices/choices.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack"><text class="back-icon">←</text><text>返回</text></view>
    <text class="header-title">三个选择</text>
    <text class="progress">2/4</text>
  </view>
  <view class="intro-section">
    <text class="intro-title">请认真思考并做出您的选择</text>
    <text class="intro-desc">这三个选择将决定您的健康管理方向</text>
  </view>
  <view class="choices-list">
    <view wx:for="{{choices}}" wx:key="id" class="choice-card">
      <view class="choice-header">
        <view class="choice-num">{{item.id}}</view>
        <text class="choice-title">{{item.title}}</text>
      </view>
      <text class="choice-question">{{item.question}}</text>
      <view class="options-list">
        <view wx:for="{{item.options}}" wx:for-item="option" wx:for-index="optIndex" wx:key="value" 
          class="option-item {{selectedChoices[item.id-1] === option.value ? 'selected' : ''}}"
          bindtap="selectOption" data-choice="{{item.id}}" data-value="{{option.value}}">
          <view class="option-radio">{{selectedChoices[item.id-1] === option.value ? '●' : '○'}}</view>
          <view class="option-content">
            <text class="option-label">{{option.label}}</text>
            <text class="option-desc">{{option.description}}</text>
          </view>
        </view>
      </view>
    </view>
  </view>
  <view class="bottom-actions">
    <button class="btn btn-outline" bindtap="goBack">上一步</button>
    <button class="btn btn-primary" bindtap="goNext" disabled="{{!isComplete}}">下一步 →</button>
  </view>
</view>
