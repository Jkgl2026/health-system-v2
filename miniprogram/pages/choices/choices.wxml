<!--pages/choices/choices.wxml-->
<view class="container">
  <!-- 进度条 -->
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{(currentIndex + 1) / choices.length * 100}}%"></view>
    <view class="progress-steps">
      <view 
        wx:for="{{choices}}" 
        wx:key="id"
        class="step {{index <= currentIndex ? 'active' : ''}} {{index < currentIndex ? 'done' : ''}}"
      >
        <text class="step-num">{{index + 1}}</text>
      </view>
    </view>
  </view>

  <!-- 选择卡片 -->
  <swiper 
    class="choice-swiper"
    current="{{currentIndex}}"
    duration="300"
    bindchange="onSwiperChange"
  >
    <swiper-item wx:for="{{choices}}" wx:key="id">
      <scroll-view class="choice-card" scroll-y>
        <!-- 选择标题 -->
        <view class="choice-header">
          <text class="choice-title">{{item.title}}</text>
          <text class="choice-question">{{item.question}}</text>
        </view>

        <!-- 选项列表 -->
        <view class="options">
          <view 
            wx:for="{{item.options}}" 
            wx:for-item="option"
            wx:for-index="optIndex"
            wx:key="value"
            class="option {{item.selected === option.value ? 'selected' : ''}}"
            data-choice-id="{{item.id}}"
            data-value="{{option.value}}"
            bindtap="selectOption"
          >
            <view class="option-radio">
              <text wx:if="{{item.selected === option.value}}">✓</text>
            </view>
            <view class="option-content">
              <text class="option-label">{{option.label}}</text>
              <text class="option-desc">{{option.desc}}</text>
            </view>
          </view>
        </view>

        <!-- 说明 -->
        <view class="choice-note">
          <text class="note-icon">💡</text>
          <text class="note-text">每个选择代表一个健康态度，请根据真实想法选择</text>
        </view>
      </scroll-view>
    </swiper-item>
  </swiper>

  <!-- 底部导航 -->
  <view class="bottom-nav">
    <button 
      wx:if="{{currentIndex > 0}}"
      class="nav-btn prev"
      bindtap="prevChoice"
    >上一个</button>
    <view wx:else class="nav-placeholder"></view>

    <button 
      wx:if="{{currentIndex < choices.length - 1}}"
      class="nav-btn next"
      bindtap="nextChoice"
    >下一个</button>
    <button 
      wx:else
      class="nav-btn next primary"
      bindtap="onNext"
    >完成选择</button>
  </view>
</view>
