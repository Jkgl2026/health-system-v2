/* pages/admin-user-detail/admin-user-detail.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; background: linear-gradient(135deg, #1e3a5f, #0f172a); color: #fff; }
.header-title { font-size: 36rpx; font-weight: 700; }
.header-back { font-size: 28rpx; color: #93c5fd; }
.content { padding: 24rpx; }
.section { margin-bottom: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 600; color: #1f2937; margin-bottom: 20rpx; }
.info-list { display: flex; flex-direction: column; gap: 16rpx; }
.info-item { display: flex; justify-content: space-between; padding: 16rpx 0; border-bottom: 1rpx solid #e5e7eb; }
.info-item:last-child { border-bottom: none; }
.info-label { font-size: 26rpx; color: #6b7280; }
.info-value { font-size: 26rpx; color: #1f2937; font-weight: 500; }
.score-card { text-align: center; padding: 24rpx; }
.score-value { display: block; font-size: 64rpx; font-weight: 700; color: #10b981; }
.score-bar { height: 16rpx; background: #e5e7eb; border-radius: 8rpx; margin-top: 16rpx; overflow: hidden; }
.score-fill { height: 100%; background: linear-gradient(90deg, #10b981, #059669); }
.tag-list { display: flex; flex-wrap: wrap; gap: 12rpx; }
.tag { padding: 12rpx 24rpx; background: #fef2f2; color: #dc2626; border-radius: 20rpx; font-size: 24rpx; }
.qa-list { display: flex; flex-direction: column; gap: 20rpx; }
.qa-item { padding: 16rpx; background: #f9fafb; border-radius: 12rpx; }
.qa-q { display: block; font-size: 26rpx; color: #6b7280; margin-bottom: 8rpx; }
.qa-a { display: block; font-size: 28rpx; color: #1f2937; font-weight: 500; }
.actions { margin-top: 24rpx; }
.btn { display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; }
.btn-secondary { background: #f3f4f6; color: #1f2937; }
.btn-block { width: 100%; }
