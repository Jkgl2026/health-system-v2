/* pages/story/story.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }
.header { padding: 32rpx; background: linear-gradient(135deg, #10b981, #059669); color: #fff; text-align: center; }
.header-title { font-size: 36rpx; font-weight: 700; }
.story-content { padding: 24rpx; }
.story-chapter { margin-bottom: 16rpx; background: #fff; border-radius: 16rpx; overflow: hidden; }
.chapter-header { display: flex; align-items: center; padding: 24rpx; border-bottom: 1rpx solid #e5e7eb; }
.chapter-num { display: block; width: 100rpx; font-size: 24rpx; color: #6b7280; }
.chapter-title { flex: 1; font-size: 30rpx; font-weight: 600; color: #1f2937; }
.chapter-arrow { font-size: 24rpx; color: #9ca3af; transition: transform 0.3s; }
.chapter-arrow.expanded { transform: rotate(180deg); }
.chapter-content { max-height: 0; overflow: hidden; transition: max-height 0.3s; }
.chapter-content.show { max-height: 2000rpx; }
.story-text { display: block; padding: 24rpx; font-size: 26rpx; line-height: 1.8; color: #4b5563; }
.philosophy { margin: 24rpx; padding: 24rpx; background: linear-gradient(135deg, #6366f1, #8b5cf6); border-radius: 16rpx; color: #fff; }
.philosophy-title { display: block; font-size: 30rpx; font-weight: 600; margin-bottom: 20rpx; }
.philosophy-list { display: flex; flex-direction: column; gap: 12rpx; }
.philosophy-item { font-size: 24rpx; opacity: 0.9; }
.bottom-actions { padding: 24rpx; background: #fff; position: fixed; bottom: 0; left: 0; right: 0; }
.btn { display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-block { width: 100%; }
