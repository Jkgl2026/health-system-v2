/* pages/story/story.wxss */
/* 系统战役故事页面 - 1:1复刻Web版样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #eff6ff 0%, #ffffff 50%, #f0fdf4 100%);
  padding-bottom: 120rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 26rpx;
}

.back-icon {
  margin-right: 8rpx;
}

.badge {
  font-size: 22rpx;
  color: #6b7280;
  padding: 8rpx 16rpx;
  border: 1rpx solid #d1d5db;
  border-radius: 8rpx;
  background: #fff;
}

/* 故事卡片 */
.story-card {
  margin: 24rpx;
  padding: 32rpx;
  background: #fff;
  border: 4rpx solid #bfdbfe;
  border-radius: 20rpx;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.1);
}

.card-header {
  text-align: center;
  margin-bottom: 32rpx;
}

.icon-wrapper {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #3b82f6, #10b981);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 16rpx;
}

.icon {
  font-size: 48rpx;
}

.card-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.card-desc {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
}

/* 内容章节 */
.card-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

.section {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.section-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.section-num {
  width: 40rpx;
  height: 40rpx;
  background: linear-gradient(135deg, #3b82f6, #10b981);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 700;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1f2937;
}

.section-text {
  padding: 20rpx;
  background: #eff6ff;
  border-radius: 12rpx;
}

.section-text text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.7;
  white-space: pre-line;
}

/* 关键问题 */
.key-question {
  display: flex;
  gap: 12rpx;
  padding: 20rpx;
  background: #fff7ed;
  border: 2rpx solid #fed7aa;
  border-radius: 12rpx;
}

.question-icon {
  font-size: 32rpx;
  flex-shrink: 0;
}

.question-content {
  flex: 1;
}

.question-text {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #1f2937;
  margin-bottom: 8rpx;
}

.answer-text {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* 结论 */
.conclusion {
  padding: 24rpx;
  background: linear-gradient(90deg, #eff6ff, #f0fdf4);
  border: 2rpx solid #bfdbfe;
  border-radius: 12rpx;
  text-align: center;
}

.conclusion text {
  font-size: 28rpx;
  font-weight: 500;
  color: #1f2937;
}

/* 健康要素区域 */
.elements-section {
  margin: 24rpx;
}

.section-title-area {
  text-align: center;
  margin-bottom: 24rpx;
}

.section-main-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  background: linear-gradient(90deg, #3b82f6, #10b981);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  margin-bottom: 8rpx;
}

.section-sub-title {
  display: block;
  font-size: 26rpx;
  color: #6b7280;
}

/* Tab切换 */
.tab-scroll {
  margin-bottom: 20rpx;
}

.tab-list {
  display: flex;
  gap: 8rpx;
  padding: 8rpx;
  background: linear-gradient(180deg, #eff6ff, #f0fdf4);
  border: 2rpx solid #bfdbfe;
  border-radius: 16rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 12rpx;
  border-radius: 12rpx;
  min-width: 90rpx;
}

.tab-item.active {
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-name {
  font-size: 20rpx;
  font-weight: 600;
}

.tab-item:not(.active) .tab-name {
  color: #374151;
}

/* 要素内容 */
.element-content {
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.05);
}

.element-header {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #f3f4f6;
}

.element-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #fff;
}

.element-info {
  flex: 1;
}

.element-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #1f2937;
}

.element-desc {
  display: block;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.story-btn {
  font-size: 22rpx;
  color: #3b82f6;
  padding: 8rpx 16rpx;
  border: 1rpx solid #3b82f6;
  border-radius: 8rpx;
}

/* 原理说明 */
.principle-section {
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.principle-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.principle-icon {
  font-size: 28rpx;
}

.principle-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #374151;
}

.principle-text {
  font-size: 26rpx;
  color: #4b5563;
  line-height: 1.7;
}

/* 完整故事 */
.full-story {
  padding: 20rpx;
  background: #fef3c7;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
}

.story-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.story-icon {
  font-size: 28rpx;
}

.story-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #92400e;
}

.story-text {
  font-size: 24rpx;
  color: #78350f;
  line-height: 1.6;
}

/* 相关症状 */
.symptoms-section {
  padding: 20rpx;
  background: #f0fdf4;
  border-radius: 12rpx;
}

.symptoms-header {
  display: flex;
  align-items: center;
  gap: 8rpx;
  margin-bottom: 12rpx;
}

.symptoms-icon {
  font-size: 28rpx;
}

.symptoms-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #166534;
}

.symptoms-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.symptom-tag {
  font-size: 22rpx;
  color: #15803d;
  background: #dcfce7;
  padding: 6rpx 12rpx;
  border-radius: 6rpx;
}

/* 底部按钮 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(10px);
  border-top: 1rpx solid #e5e7eb;
}

.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.btn::after {
  border: none;
}

.btn-primary {
  background: linear-gradient(135deg, #3b82f6, #10b981);
  color: #fff;
}

.btn-block {
  width: 100%;
}
