<!--pages/story/story.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">系统战役故事</text>
  </view>
  
  <view class="story-content">
    <view class="story-chapter" wx:for="{{chapters}}" wx:key="id">
      <view class="chapter-header" bindtap="toggleChapter" data-id="{{item.id}}">
        <text class="chapter-num">第{{item.id}}章</text>
        <text class="chapter-title">{{item.title}}</text>
        <text class="chapter-arrow {{item.expanded ? 'expanded' : ''}}">▼</text>
      </view>
      <view class="chapter-content {{item.expanded ? 'show' : ''}}">
        <text class="story-text">{{item.content}}</text>
      </view>
    </view>
  </view>
  
  <view class="philosophy">
    <text class="philosophy-title">💡 核心理念</text>
    <view class="philosophy-list">
      <text class="philosophy-item">• 整体观念：人是一个有机整体，各部分相互联系</text>
      <text class="philosophy-item">• 辨证论治：因人、因时、因地制宜</text>
      <text class="philosophy-item">• 治未病：预防为主，防患于未然</text>
      <text class="philosophy-item">• 天人合一：顺应自然规律生活</text>
    </view>
  </view>
  
  <view class="bottom-actions">
    <button class="btn btn-primary btn-block" bindtap="goToQuestions">填写健康七问 →</button>
  </view>
</view>
