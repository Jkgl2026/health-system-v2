<!--pages/questions/questions.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">健康七问 (V2)</text>
    <text class="header-subtitle">生活习惯 · 主动预防</text>
  </view>
  
  <view class="progress-bar">
    <view class="progress-fill" style="width: {{(currentIndex + 1) / questions.length * 100}}%;"></view>
    <text class="progress-text">{{currentIndex + 1}} / {{questions.length}}</text>
  </view>
  
  <view class="question-card" wx:if="{{currentIndex < questions.length}}">
    <text class="question-num">问题 {{currentIndex + 1}}</text>
    <text class="question-text">{{questions[currentIndex].question}}</text>
    
    <view class="options">
      <view 
        wx:for="{{questions[currentIndex].options}}" 
        wx:key="value" 
        class="option-item {{answers[questions[currentIndex].id] === item.value ? 'selected' : ''}}"
        bindtap="selectAnswer"
        data-id="{{questions[currentIndex].id}}"
        data-value="{{item.value}}"
      >
        <text class="option-label">{{item.label}}</text>
      </view>
    </view>
    
    <view class="nav-btns">
      <button class="btn btn-secondary" bindtap="prevQuestion" wx:if="{{currentIndex > 0}}">上一题</button>
      <button class="btn btn-primary {{answers[questions[currentIndex].id] ? '' : 'disabled'}}" bindtap="nextQuestion">
        {{currentIndex === questions.length - 1 ? '提交' : '下一题'}}
      </button>
    </view>
  </view>
  
  <view class="complete-card" wx:else>
    <text class="complete-icon">✅</text>
    <text class="complete-title">七问已完成</text>
    <text class="complete-desc">感谢您的耐心填写，我们将根据您的答案提供更精准的健康建议</text>
    <button class="btn btn-primary btn-block" bindtap="goToResult">查看分析结果 →</button>
  </view>
</view>
