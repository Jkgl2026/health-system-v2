/* pages/history-compare/history-compare.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  padding-bottom: 40rpx;
}

/* 头部 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: white;
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.header-right {
  width: 80rpx;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 200rpx 48rpx;
}

.loading-icon {
  font-size: 80rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 24rpx;
}

/* 内容 */
.content {
  padding: 24rpx;
}

/* 卡片 */
.section-card {
  background: white;
  border-radius: 20rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.section-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

/* 表格 */
.table-container {
  overflow-x: auto;
}

.table {
  min-width: 100%;
}

.table-row {
  display: flex;
  border-bottom: 1rpx solid #f3f4f6;
}

.table-row:last-child {
  border-bottom: none;
}

.table-header {
  background: #f9fafb;
}

.table-cell {
  flex: 1;
  min-width: 120rpx;
  padding: 20rpx 12rpx;
  text-align: center;
  font-size: 24rpx;
  color: #374151;
}

.cell-label {
  font-weight: 600;
  color: #111827;
  background: #f9fafb;
}

.cell-date {
  font-size: 20rpx;
  color: #6b7280;
}

.cell-score .score {
  font-weight: 700;
  font-size: 28rpx;
}

.score-good { color: #22c55e; }
.score-normal { color: #eab308; }
.score-low { color: #ef4444; }

/* 柱状图 */
.chart-container {
  padding: 20rpx 0;
}

.bar-chart {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 300rpx;
  padding: 0 20rpx;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
}

.bar-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.bar-wrapper {
  width: 60rpx;
  height: 200rpx;
  display: flex;
  align-items: flex-end;
}

.bar {
  width: 100%;
  border-radius: 8rpx 8rpx 0 0;
  transition: height 0.5s;
}

.bar-label {
  font-size: 20rpx;
  color: #6b7280;
  margin-top: 12rpx;
}

/* 折线图样式 */
.line-chart {
  padding: 20rpx;
}

.line-values {
  display: flex;
  justify-content: space-around;
  margin-bottom: 12rpx;
}

.line-value {
  font-size: 24rpx;
  font-weight: 600;
  color: #3b82f6;
}

.line-bars {
  display: flex;
  justify-content: space-around;
  align-items: flex-end;
  height: 160rpx;
  border-bottom: 2rpx solid #e5e7eb;
  padding-bottom: 12rpx;
}

.line-bar-item {
  width: 40rpx;
  display: flex;
  align-items: flex-end;
}

.line-bar {
  width: 100%;
  background: linear-gradient(180deg, #3b82f6, #60a5fa);
  border-radius: 4rpx 4rpx 0 0;
}

.line-labels {
  display: flex;
  justify-content: space-around;
  margin-top: 12rpx;
}

.line-label {
  font-size: 20rpx;
  color: #6b7280;
}

/* 健康要素 */
.elements-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.element-item {
  padding: 20rpx;
  background: #f9fafb;
  border-radius: 12rpx;
}

.element-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.element-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.element-trend {
  font-size: 24rpx;
  font-weight: 500;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.element-trend.improved {
  color: #22c55e;
  background: #dcfce7;
}

.element-trend.worsened {
  color: #ef4444;
  background: #fee2e2;
}

.element-trend.stable {
  color: #6b7280;
  background: #f3f4f6;
}

.element-compare {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
}

.element-count-box {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.element-count-label {
  font-size: 22rpx;
  color: #9ca3af;
}

.element-count-value {
  font-size: 32rpx;
  font-weight: 700;
  color: #374151;
}

.element-count-value.improved {
  color: #22c55e;
}

.element-count-value.worsened {
  color: #ef4444;
}

.element-arrow {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 症状变化 */
.change-section {
  margin-bottom: 24rpx;
}

.change-section:last-child {
  margin-bottom: 0;
}

.change-title {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.change-title.improved { color: #22c55e; }
.change-title.worsened { color: #ef4444; }
.change-title.persistent { color: #6b7280; }

.change-icon {
  margin-right: 8rpx;
}

.symptom-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.symptom-tag {
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
}

.symptom-tag.improved {
  background: #dcfce7;
  color: #166534;
}

.symptom-tag.worsened {
  background: #fee2e2;
  color: #991b1b;
}

.symptom-tag.persistent {
  background: #f3f4f6;
  color: #374151;
}

/* AI建议 */
.ai-section {
  background: linear-gradient(135deg, #fef3c7, #fde68a);
  border: 2rpx solid #f59e0b;
}

.ai-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.ai-empty-icon {
  font-size: 60rpx;
  margin-bottom: 16rpx;
}

.ai-empty-text {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.generate-btn {
  background: linear-gradient(135deg, #f59e0b, #d97706);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  padding: 20rpx 48rpx;
  border-radius: 12rpx;
  border: none;
}

.ai-loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-icon-animate {
  font-size: 60rpx;
  animation: bounce 1s infinite;
}

@keyframes bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-20rpx); }
}

.ai-loading-text {
  font-size: 26rpx;
  color: #6b7280;
  margin-top: 16rpx;
}

.ai-content {
  padding: 20rpx;
}

.ai-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  white-space: pre-wrap;
}

.regenerate-btn {
  margin-top: 24rpx;
  background: white;
  color: #f59e0b;
  font-size: 24rpx;
  padding: 12rpx 32rpx;
  border-radius: 8rpx;
  border: 1rpx solid #f59e0b;
}

/* 底部操作 */
.bottom-actions {
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.action-btn.primary {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
}

.action-btn.secondary {
  background: white;
  color: #3b82f6;
  border: 2rpx solid #3b82f6;
}
