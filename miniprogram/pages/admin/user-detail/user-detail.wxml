<!--pages/admin/user-detail/user-detail.wxml-->
<view class="container">
  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="loading">
    <view class="loading-icon"></view>
    <text>加载中...</text>
  </view>

  <!-- 用户信息 -->
  <view wx:else class="content">
    <!-- 基本信息卡 -->
    <view class="info-card">
      <view class="info-header">
        <view class="user-avatar">
          <text>{{userInfo.name[0]}}</text>
        </view>
        <view class="user-basic">
          <text class="user-name">{{userInfo.name}}</text>
          <text class="user-phone">{{userInfo.phone}}</text>
        </view>
        <view class="call-btn" bindtap="callUser">
          <text>📞</text>
        </view>
      </view>

      <view class="info-grid">
        <view class="info-item">
          <text class="info-label">年龄</text>
          <text class="info-value">{{userInfo.age}}岁</text>
        </view>
        <view class="info-item">
          <text class="info-label">性别</text>
          <text class="info-value">{{userInfo.gender}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">身高</text>
          <text class="info-value">{{userInfo.height}}cm</text>
        </view>
        <view class="info-item">
          <text class="info-label">体重</text>
          <text class="info-value">{{userInfo.weight}}kg</text>
        </view>
        <view class="info-item">
          <text class="info-label">BMI</text>
          <text class="info-value">{{userInfo.bmi}}</text>
        </view>
        <view class="info-item">
          <text class="info-label">注册时间</text>
          <text class="info-value">{{userInfo.registerDate}}</text>
        </view>
      </view>
    </view>

    <!-- 检测历史 -->
    <view class="history-card">
      <view class="card-header">
        <text class="card-icon">📊</text>
        <text class="card-title">检测历史</text>
      </view>

      <view class="history-list">
        <view 
          wx:for="{{checkHistory}}" 
          wx:key="date"
          class="history-item"
          data-date="{{item.date}}"
          bindtap="viewCheckDetail"
        >
          <view class="history-left">
            <text class="history-date">{{item.date}}</text>
            <text class="history-stats">症状{{item.symptoms}}项 · 习惯{{item.habits}}项</text>
          </view>
          <view class="history-score">
            <text class="score-value">{{item.score}}</text>
            <text class="score-label">分</text>
          </view>
          <text class="history-arrow">›</text>
        </view>
      </view>
    </view>

    <!-- 操作按钮 -->
    <view class="actions">
      <button class="action-btn danger" bindtap="deleteUser">
        删除用户
      </button>
    </view>
  </view>
</view>
