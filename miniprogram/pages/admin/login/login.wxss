/* pages/admin/login/login.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 40rpx 40rpx;
  box-sizing: border-box;
}

/* 顶部 */
.header {
  text-align: center;
  margin-bottom: 80rpx;
}

.header-icon {
  font-size: 100rpx;
  display: block;
  margin-bottom: 30rpx;
}

.header-title {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: white;
  margin-bottom: 20rpx;
}

.header-desc {
  display: block;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}

/* 登录表单 */
.login-form {
  width: 100%;
  max-width: 600rpx;
}

.form-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 50rpx;
  padding: 0 30rpx;
  margin-bottom: 30rpx;
  height: 100rpx;
}

.input-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
}

.input {
  flex: 1;
  font-size: 30rpx;
  color: #333;
}

.toggle-password {
  padding: 10rpx;
}

.toggle-password text {
  font-size: 36rpx;
}

/* 登录按钮 */
.login-btn {
  width: 100%;
  height: 100rpx;
  line-height: 100rpx;
  background: white;
  color: #1e3a8a;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 50rpx;
  margin-top: 20rpx;
}

.login-btn.loading {
  opacity: 0.7;
}

/* 提示 */
.hint {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 40rpx;
}

.hint-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
}

.hint-text {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
}

/* 底部 */
.footer {
  position: fixed;
  bottom: 40rpx;
  text-align: center;
}

.footer-text {
  display: block;
  font-size: 24rpx;
  color: rgba(255,255,255,0.6);
  margin-bottom: 15rpx;
}

.footer-link {
  font-size: 26rpx;
  color: white;
  text-decoration: underline;
}
