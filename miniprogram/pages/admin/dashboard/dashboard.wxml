<!--pages/admin/dashboard/dashboard.wxml-->
<view class="container">
  <!-- 顶部 -->
  <view class="header">
    <view class="header-left">
      <text class="header-title">后台管理</text>
      <text class="header-desc">数据概览</text>
    </view>
    <view class="header-right">
      <button class="home-btn" bindtap="goHome">
        <text>🏠</text>
      </button>
      <button class="logout-btn" bindtap="logout">
        <text>退出</text>
      </button>
    </view>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-grid">
    <view class="stat-card blue">
      <text class="stat-icon">👥</text>
      <text class="stat-value">{{stats.totalUsers}}</text>
      <text class="stat-label">总用户数</text>
    </view>
    <view class="stat-card green">
      <text class="stat-icon">📈</text>
      <text class="stat-value">{{stats.todayUsers}}</text>
      <text class="stat-label">今日新增</text>
    </view>
    <view class="stat-card orange">
      <text class="stat-icon">✅</text>
      <text class="stat-value">{{stats.totalChecks}}</text>
      <text class="stat-label">总检测数</text>
    </view>
    <view class="stat-card purple">
      <text class="stat-icon">🔍</text>
      <text class="stat-value">{{stats.todayChecks}}</text>
      <text class="stat-label">今日检测</text>
    </view>
  </view>

  <!-- 标签切换 -->
  <view class="tabs">
    <view 
      class="tab {{activeTab === 'overview' ? 'active' : ''}}"
      data-tab="overview"
      bindtap="switchTab"
    >
      <text>数据概览</text>
    </view>
    <view 
      class="tab {{activeTab === 'users' ? 'active' : ''}}"
      data-tab="users"
      bindtap="switchTab"
    >
      <text>用户列表</text>
    </view>
  </view>

  <!-- 内容区域 -->
  <scroll-view class="content-area" scroll-y>
    <!-- 数据概览 -->
    <view wx:if="{{activeTab === 'overview'}}" class="overview-content">
      <!-- 图表占位 -->
      <view class="chart-placeholder">
        <text class="chart-icon">📊</text>
        <text class="chart-title">用户增长趋势</text>
        <text class="chart-desc">数据可视化功能开发中</text>
      </view>

      <!-- 快捷操作 -->
      <view class="quick-actions">
        <view class="action-card" bindtap="exportData">
          <text class="action-icon">📥</text>
          <text class="action-text">导出数据</text>
        </view>
        <view class="action-card">
          <text class="action-icon">⚙️</text>
          <text class="action-text">系统设置</text>
        </view>
      </view>
    </view>

    <!-- 用户列表 -->
    <view wx:if="{{activeTab === 'users'}}" class="users-content">
      <view class="user-list">
        <view 
          wx:for="{{recentUsers}}" 
          wx:key="id"
          class="user-item"
          data-id="{{item.id}}"
          bindtap="viewUser"
        >
          <view class="user-avatar">
            <text>{{item.name[0]}}</text>
          </view>
          <view class="user-info">
            <text class="user-name">{{item.name}}</text>
            <text class="user-phone">{{item.phone}}</text>
          </view>
          <view class="user-score">
            <text class="score-value">{{item.score}}</text>
            <text class="score-label">健康分</text>
          </view>
          <view class="user-date">
            <text>{{item.date}}</text>
          </view>
          <text class="user-arrow">›</text>
        </view>
      </view>
    </view>
  </scroll-view>
</view>
