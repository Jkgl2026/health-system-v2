/* pages/admin/dashboard/dashboard.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

/* 顶部 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: linear-gradient(135deg, #1e3a8a, #3b82f6);
  color: white;
}

.header-left {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  opacity: 0.8;
}

.header-right {
  display: flex;
  gap: 15rpx;
}

.home-btn, .logout-btn {
  padding: 15rpx 25rpx;
  font-size: 26rpx;
  border-radius: 30rpx;
  background: rgba(255,255,255,0.2);
  color: white;
}

/* 统计卡片 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
  margin-top: -30rpx;
}

.stat-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.stat-card.blue { border-left: 6rpx solid #3b82f6; }
.stat-card.green { border-left: 6rpx solid #10b981; }
.stat-card.orange { border-left: 6rpx solid #f59e0b; }
.stat-card.purple { border-left: 6rpx solid #8b5cf6; }

.stat-icon {
  font-size: 40rpx;
  display: block;
  margin-bottom: 15rpx;
}

.stat-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 10rpx;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 标签 */
.tabs {
  display: flex;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  padding: 25rpx 0;
  text-align: center;
  font-size: 30rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #3b82f6;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #3b82f6;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  padding: 20rpx;
}

/* 概览 */
.chart-placeholder {
  background: white;
  border-radius: 16rpx;
  padding: 60rpx 30rpx;
  text-align: center;
  margin-bottom: 20rpx;
}

.chart-icon {
  font-size: 80rpx;
  display: block;
  margin-bottom: 20rpx;
}

.chart-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 15rpx;
}

.chart-desc {
  font-size: 26rpx;
  color: #999;
}

.quick-actions {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.action-card {
  background: white;
  border-radius: 16rpx;
  padding: 40rpx 30rpx;
  text-align: center;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.action-icon {
  font-size: 48rpx;
  display: block;
  margin-bottom: 15rpx;
}

.action-text {
  font-size: 28rpx;
  color: #333;
}

/* 用户列表 */
.user-list {
  display: grid;
  gap: 15rpx;
}

.user-item {
  display: flex;
  align-items: center;
  background: white;
  border-radius: 16rpx;
  padding: 25rpx;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.05);
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 32rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.user-info {
  flex: 1;
}

.user-name {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 8rpx;
}

.user-phone {
  font-size: 24rpx;
  color: #999;
}

.user-score {
  text-align: center;
  margin-right: 20rpx;
}

.score-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #3b82f6;
}

.score-label {
  font-size: 20rpx;
  color: #999;
}

.user-date {
  font-size: 24rpx;
  color: #999;
  margin-right: 15rpx;
}

.user-arrow {
  font-size: 32rpx;
  color: #ccc;
}
