<!--pages/health-result/health-result.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack"><text class="back-icon">←</text><text>返回</text></view>
    <text class="header-title">健康分析结果</text>
    <view class="placeholder"></view>
  </view>
  
  <!-- 健康评分 -->
  <view class="score-section">
    <view class="score-circle">
      <text class="score-value">{{healthScore}}</text>
      <text class="score-label">健康评分</text>
    </view>
    <view class="score-level {{scoreLevel}}">{{scoreText}}</view>
  </view>
  
  <!-- 偺康要素分析 -->
  <view class="analysis-section">
    <text class="section-title">健康要素分析</text>
    <view class="elements-list">
      <view wx:for="{{elements}}" wx:key="key" class="element-item">
        <view class="element-header">
          <text class="element-icon">{{item.icon}}</text>
          <text class="element-title">{{item.title}}</text>
        </view>
        <view class="element-bar">
          <view class="element-fill" style="width: {{item.score}}%;"></view>
        </view>
        <text class="element-score">{{item.score}}分</text>
      </view>
    </view>
  </view>
  
  <!-- 改善建议 -->
  <view class="suggestions-section">
    <text class="section-title">改善建议</text>
    <view class="suggestions-list">
      <view wx:for="{{suggestions}}" wx:key="*this" class="suggestion-item">
        <text class="suggestion-dot">•</text>
        <text class="suggestion-text">{{item}}</text>
      </view>
    </view>
  </view>
  
  <view class="bottom-actions">
    <button class="btn btn-primary btn-block" bindtap="goToSolution">查看我的方案 →</button>
  </view>
</view>
