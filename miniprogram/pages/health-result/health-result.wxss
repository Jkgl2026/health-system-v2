/* pages/health-result/health-result.wxss */
.container { min-height: 100vh; background: linear-gradient(to bottom, #eff6ff, #f0fdf4); padding-bottom: 160rpx; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; background: #fff; }
.header-title { font-size: 32rpx; font-weight: 600; }
.placeholder { width: 80rpx; }
.score-section { display: flex; flex-direction: column; align-items: center; padding: 48rpx 32rpx; }
.score-circle { width: 240rpx; height: 240rpx; border-radius: 50%; background: linear-gradient(135deg, #10b981, #3b82f6); display: flex; flex-direction: column; align-items: center; justify-content: center; box-shadow: 0 16rpx 48rpx rgba(16, 185, 129, 0.3); }
.score-value { font-size: 72rpx; font-weight: 700; color: #fff; }
.score-label { font-size: 24rpx; color: rgba(255,255,255,0.8); margin-top: 8rpx; }
.score-level { margin-top: 24rpx; padding: 12rpx 32rpx; border-radius: 24rpx; font-size: 28rpx; font-weight: 600; }
.score-level.good { background: #d1fae5; color: #059669; }
.score-level.normal { background: #fef3c7; color: #d97706; }
.score-level.warning { background: #fee2e2; color: #dc2626; }
.analysis-section { margin: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 600; color: #1f2937; margin-bottom: 20rpx; }
.elements-list { display: flex; flex-direction: column; gap: 20rpx; }
.element-item { display: flex; align-items: center; gap: 16rpx; }
.element-header { width: 160rpx; display: flex; align-items: center; gap: 8rpx; }
.element-icon { font-size: 28rpx; }
.element-title { font-size: 26rpx; color: #374151; }
.element-bar { flex: 1; height: 16rpx; background: #e5e7eb; border-radius: 8rpx; overflow: hidden; }
.element-fill { height: 100%; background: linear-gradient(90deg, #10b981, #3b82f6); border-radius: 8rpx; }
.element-score { width: 80rpx; text-align: right; font-size: 24rpx; font-weight: 600; color: #10b981; }
.suggestions-section { margin: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; }
.suggestions-list { display: flex; flex-direction: column; gap: 16rpx; }
.suggestion-item { display: flex; align-items: flex-start; gap: 12rpx; }
.suggestion-dot { color: #10b981; font-size: 28rpx; }
.suggestion-text { flex: 1; font-size: 26rpx; color: #374151; line-height: 1.5; }
.bottom-actions { padding: 24rpx; background: #fff; position: fixed; bottom: 0; left: 0; right: 0; }
.btn { display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-block { width: 100%; }
