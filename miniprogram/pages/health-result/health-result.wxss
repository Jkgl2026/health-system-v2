/* pages/health-result/health-result.wxss */
.container {
  min-height: 100vh;
  background: #f5f5f5;
  display: flex;
  flex-direction: column;
}

.loading {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.loading-icon {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #e0e0e0;
  border-top-color: #3498db;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* 评分卡 */
.score-card {
  padding: 40rpx 30rpx;
  background: linear-gradient(135deg, #667eea, #764ba2);
  display: flex;
  align-items: center;
  justify-content: space-around;
}

.score-circle {
  width: 180rpx;
  height: 180rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-inner {
  width: 150rpx;
  height: 150rpx;
  border-radius: 50%;
  background: white;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.score-num {
  font-size: 48rpx;
  font-weight: bold;
  color: #333;
}

.score-label {
  font-size: 20rpx;
  color: #666;
}

.risk-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.risk-label {
  font-size: 26rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 10rpx;
}

.risk-value {
  font-size: 36rpx;
  font-weight: bold;
}

/* 标签 */
.tabs {
  display: flex;
  background: white;
  border-bottom: 1rpx solid #eee;
}

.tab {
  flex: 1;
  padding: 25rpx 0;
  text-align: center;
  font-size: 28rpx;
  color: #666;
  position: relative;
}

.tab.active {
  color: #667eea;
  font-weight: bold;
}

.tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #667eea;
  border-radius: 2rpx;
}

/* 内容区域 */
.content-area {
  flex: 1;
  padding: 20rpx;
  max-height: calc(100vh - 380rpx);
}

.tab-content {
  padding-bottom: 100rpx;
}

/* 信息区块 */
.info-section {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
  margin-bottom: 20rpx;
}

.section-title {
  display: flex;
  align-items: center;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 20rpx;
}

.title-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.info-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
}

.info-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
}

.stat-item {
  text-align: center;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.stat-num {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #667eea;
}

.stat-label {
  font-size: 24rpx;
  color: #666;
}

/* 问题列表 */
.issue-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
}

.issue-item:last-child {
  border-bottom: none;
}

.issue-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.issue-name {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.issue-score {
  font-size: 28rpx;
  color: #666;
}

.issue-bar {
  height: 8rpx;
  background: #e0e0e0;
  border-radius: 4rpx;
  margin-bottom: 12rpx;
}

.issue-bar-fill {
  height: 100%;
  border-radius: 4rpx;
  transition: width 0.3s;
}

.issue-suggestion {
  font-size: 24rpx;
  color: #999;
}

/* 详细分析 */
.detail-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.detail-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 25rpx;
}

.detail-section {
  margin-bottom: 25rpx;
}

.detail-subtitle {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 15rpx;
  display: block;
}

.choices-list, .requirements-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.choice-badge, .req-badge {
  padding: 12rpx 24rpx;
  background: #f0f0f0;
  border-radius: 20rpx;
  font-size: 24rpx;
  color: #666;
}

.req-badge.agreed {
  background: #e8f5e9;
  color: #27ae60;
}

/* 中医分析 */
.tcm-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.tcm-header {
  display: flex;
  align-items: center;
  margin-bottom: 25rpx;
}

.tcm-icon {
  font-size: 40rpx;
  margin-right: 15rpx;
}

.tcm-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.tcm-grid {
  display: grid;
  gap: 20rpx;
}

.tcm-item {
  display: flex;
  justify-content: space-between;
  padding: 20rpx;
  background: #f8f9fa;
  border-radius: 12rpx;
}

.tcm-label {
  font-size: 28rpx;
  color: #666;
}

.tcm-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

/* 建议 */
.suggestions-list {
  display: grid;
  gap: 20rpx;
}

.suggestion-card {
  background: white;
  border-radius: 16rpx;
  padding: 30rpx;
}

.suggestion-header {
  display: flex;
  align-items: center;
  margin-bottom: 15rpx;
}

.suggestion-icon {
  font-size: 36rpx;
  margin-right: 15rpx;
}

.suggestion-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.suggestion-content {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
}

/* 操作按钮 */
.actions {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20rpx;
  padding: 30rpx 0;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 140rpx;
  background: white;
  border-radius: 16rpx;
  font-size: 24rpx;
  color: #666;
}

.btn-icon {
  font-size: 36rpx;
  margin-bottom: 10rpx;
}

.action-btn.share {
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: white;
}

.action-btn.save {
  background: linear-gradient(135deg, #27ae60, #2ecc71);
  color: white;
}

.action-btn.recheck {
  background: #f5f5f5;
}
