<!--pages/personal-info/personal-info.wxml-->
<!--个人信息页 - 基于Web版personal-info/page.tsx精确转换-->

<view class="container">
  <!-- 头部导航 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
      <text>返回</text>
    </view>
    <text class="header-title">个人信息</text>
    <view class="placeholder"></view>
  </view>

  <!-- 自动保存提示 -->
  <view wx:if="{{lastSaveTime}}" class="auto-save-tip">
    <text class="save-icon">💾</text>
    <text>已自动保存</text>
  </view>

  <!-- 表单区域 -->
  <view class="form-card">
    <view class="card-header">
      <text class="card-icon">👤</text>
      <view>
        <text class="card-title">基本信息</text>
        <text class="card-desc">请填写您的个人信息</text>
      </view>
    </view>

    <view class="form-content">
      <!-- 姓名 -->
      <view class="form-group">
        <text class="form-label required">姓名</text>
        <input 
          class="input" 
          placeholder="请输入姓名" 
          value="{{formData.name}}"
          bindinput="handleInput"
          data-field="name"
        />
      </view>

      <!-- 手机号 -->
      <view class="form-group">
        <text class="form-label required">手机号</text>
        <input 
          class="input" 
          type="number"
          placeholder="请输入手机号" 
          maxlength="11"
          value="{{formData.phone}}"
          bindinput="handleInput"
          data-field="phone"
        />
      </view>

      <!-- 性别 - 按钮选择形式 -->
      <view class="form-group">
        <text class="form-label required">性别</text>
        <view class="gender-buttons">
          <view 
            class="gender-btn {{formData.gender === '男' ? 'active' : ''}}" 
            bindtap="selectGender" 
            data-gender="男"
          >
            <text class="gender-icon">👨</text>
            <text class="gender-text">男</text>
          </view>
          <view 
            class="gender-btn {{formData.gender === '女' ? 'active' : ''}}" 
            bindtap="selectGender" 
            data-gender="女"
          >
            <text class="gender-icon">👩</text>
            <text class="gender-text">女</text>
          </view>
        </view>
      </view>

      <!-- 年龄 -->
      <view class="form-group">
        <text class="form-label required">年龄</text>
        <input 
          class="input" 
          type="number"
          placeholder="请输入年龄" 
          maxlength="3"
          value="{{formData.age}}"
          bindinput="handleInput"
          data-field="age"
        />
        <text class="form-hint">岁</text>
      </view>

      <!-- 身高 -->
      <view class="form-group">
        <text class="form-label required">身高</text>
        <input 
          class="input" 
          type="digit"
          placeholder="请输入身高" 
          value="{{formData.height}}"
          bindinput="handleInput"
          data-field="height"
        />
        <text class="form-hint">cm</text>
      </view>

      <!-- 体重 -->
      <view class="form-group">
        <text class="form-label required">体重</text>
        <input 
          class="input" 
          type="digit"
          placeholder="请输入体重" 
          value="{{formData.weight}}"
          bindinput="handleInput"
          data-field="weight"
        />
        <text class="form-hint">kg</text>
      </view>

      <!-- BMI显示 -->
      <view wx:if="{{bmi}}" class="bmi-section">
        <view class="bmi-header">
          <text class="bmi-icon">📊</text>
          <text class="bmi-title">BMI指数</text>
        </view>
        <view class="bmi-content">
          <text class="bmi-value {{bmiColorClass}}">{{bmi}}</text>
          <text class="bmi-category {{bmiColorClass}}">{{bmiCategory}}</text>
        </view>
        <view class="bmi-bar">
          <view class="bmi-range bmi-range-thin">偏瘦</view>
          <view class="bmi-range bmi-range-normal">正常</view>
          <view class="bmi-range bmi-range-overweight">超重</view>
          <view class="bmi-range bmi-range-obese">肥胖</view>
          <view class="bmi-indicator" style="left: {{bmiPosition}}%;"></view>
        </view>
        <text class="bmi-formula">BMI = 体重(kg) ÷ 身高(m)²</text>
      </view>

      <!-- 血压 -->
      <view class="form-group">
        <text class="form-label">血压</text>
        <input 
          class="input" 
          placeholder="如：120/80" 
          value="{{formData.bloodPressure}}"
          bindinput="handleInput"
          data-field="bloodPressure"
        />
      </view>

      <!-- 职业 -->
      <view class="form-group">
        <text class="form-label">职业</text>
        <input 
          class="input" 
          placeholder="请输入职业" 
          value="{{formData.occupation}}"
          bindinput="handleInput"
          data-field="occupation"
        />
      </view>

      <!-- 地址 -->
      <view class="form-group">
        <text class="form-label">地址</text>
        <input 
          class="input" 
          placeholder="请输入地址" 
          value="{{formData.address}}"
          bindinput="handleInput"
          data-field="address"
        />
      </view>
    </view>
  </view>

  <!-- 错误提示 -->
  <view wx:if="{{error}}" class="error-card">
    <view class="error-header">
      <text class="error-icon">⚠️</text>
      <text class="error-title">保存失败</text>
    </view>
    <view class="error-content">
      <text class="error-message">{{error.message}}</text>
      <text class="error-detail">错误代码：{{error.status}}</text>
    </view>
    <view class="error-suggestion">{{errorSuggestion}}</view>
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="btn btn-primary btn-block btn-lg" bindtap="handleSubmit" loading="{{isSaving}}">
      {{isSaving ? '保存中...' : '保存并继续'}}
    </button>
    <text class="submit-hint">保存后将进入身体语言简表页面</text>
  </view>
</view>
