/* pages/symptoms300/symptoms300.wxss */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f9fafb;
}

.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx;
  color: #ffffff;
}

.header.purple {
  background: linear-gradient(135deg, #8b5cf6 0%, #7c3aed 100%);
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  display: block;
}

.header-desc {
  font-size: 24rpx;
  opacity: 0.9;
  margin-top: 4rpx;
  display: block;
}

.selected-count {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
}

.count-num {
  font-size: 36rpx;
  font-weight: 700;
}

.count-label {
  font-size: 20rpx;
  opacity: 0.9;
}

.search-bar {
  padding: 16rpx 24rpx;
  background: #ffffff;
}

.search-input {
  height: 72rpx;
  padding: 0 24rpx;
  background: #f3f4f6;
  border-radius: 36rpx;
  font-size: 28rpx;
}

.symptom-list {
  flex: 1;
  padding: 16rpx 24rpx;
  padding-bottom: 160rpx;
}

.symptom-item {
  display: flex;
  align-items: center;
  padding: 20rpx;
  margin-bottom: 12rpx;
  background: #ffffff;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
}

.symptom-item.selected {
  background: #f5f3ff;
  border-color: #8b5cf6;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 4rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-size: 24rpx;
  color: #ffffff;
}

.checkbox.checked {
  background: #8b5cf6;
  border-color: #8b5cf6;
}

.symptom-content {
  flex: 1;
}

.symptom-name {
  font-size: 28rpx;
  color: #1f2937;
  display: block;
}

.symptom-category {
  font-size: 22rpx;
  color: #8b5cf6;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 16rpx;
  padding: 24rpx;
  background: #ffffff;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}
