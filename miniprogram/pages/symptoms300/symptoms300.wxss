/* pages/symptoms300/symptoms300.wxss */
.container { min-height: 100vh; background: #f5f5f5; display: flex; flex-direction: column; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; background: #fff; }
.header-title { font-size: 32rpx; font-weight: 600; }
.progress-info { background: #8b5cf6; color: #fff; padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; }
.progress-bar-container { padding: 16rpx 32rpx; background: #fff; }
.progress-bar { height: 8rpx; background: #e5e7eb; border-radius: 4rpx; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #8b5cf6, #ec4899); border-radius: 4rpx; }
.search-section { padding: 16rpx 24rpx; background: #fff; }
.search-bar { display: flex; align-items: center; background: #f3f4f6; border-radius: 24rpx; padding: 16rpx 24rpx; }
.search-input { flex: 1; font-size: 28rpx; margin-left: 12rpx; }
.symptom-list { flex: 1; padding: 16rpx 24rpx; background: #fff; margin: 0 24rpx; border-radius: 16rpx; max-height: 600rpx; }
.symptom-item { display: flex; align-items: flex-start; padding: 20rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.symptom-checkbox { width: 48rpx; height: 48rpx; border: 3rpx solid #d1d5db; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; }
.symptom-checkbox.checked { background: #8b5cf6; border-color: #8b5cf6; }
.checkbox-icon { color: #fff; font-size: 24rpx; font-weight: 700; }
.symptom-content { flex: 1; }
.symptom-name { display: block; font-size: 28rpx; color: #1f2937; margin-bottom: 4rpx; }
.symptom-desc { display: block; font-size: 22rpx; color: #9ca3af; }
.selected-summary { margin: 16rpx 24rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; }
.summary-header { display: flex; align-items: center; gap: 12rpx; }
.bottom-actions { display: flex; gap: 16rpx; padding: 24rpx; background: #fff; }
.btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-outline { background: #fff; border: 2rpx solid #e5e7eb; color: #6b7280; }
