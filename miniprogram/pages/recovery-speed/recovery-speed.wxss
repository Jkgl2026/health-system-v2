/* pages/recovery-speed/recovery-speed.wxss */
/* 恢复速度8要素页面样式 - 1:1复刻Web版 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #e0e7ff 0%, #ffffff 50%, #dcfce7 100%);
  padding-bottom: 140rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-badge {
  padding: 8rpx 24rpx;
  border: 2rpx solid #818cf8;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #4338ca;
  background: #e0e7ff;
}

/* 内容 */
.content {
  padding: 32rpx;
}

/* 标题卡片 */
.title-card {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #818cf8;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.title-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx auto;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.title-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 介绍卡片 */
.intro-card {
  display: flex;
  padding: 24rpx;
  background: #eef2ff;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #c7d2fe;
}

.intro-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.intro-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  font-style: italic;
}

/* 要素卡片 */
.factors-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #e5e7eb;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.factor-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.factor-item {
  padding: 32rpx;
  background: white;
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
}

.factor-header {
  display: flex;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.factor-num {
  width: 56rpx;
  height: 56rpx;
  background: linear-gradient(135deg, #6366f1, #8b5cf6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 26rpx;
  font-weight: 700;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.factor-question {
  flex: 1;
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  line-height: 1.6;
}

.factor-badge {
  padding: 4rpx 16rpx;
  background: #22c55e;
  color: white;
  font-size: 22rpx;
  border-radius: 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.factor-answer {
  margin-bottom: 16rpx;
  padding-left: 72rpx;
}

.answer-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.answer-text {
  font-size: 24rpx;
  color: #111827;
}

.factor-principle {
  display: flex;
  align-items: flex-start;
  padding: 16rpx;
  background: #eef2ff;
  border-radius: 12rpx;
  margin-left: 72rpx;
}

.principle-icon {
  font-size: 24rpx;
  margin-right: 8rpx;
}

.principle-label {
  font-size: 22rpx;
  font-weight: 600;
  color: #4338ca;
}

.principle-text {
  font-size: 22rpx;
  color: #4338ca;
  flex: 1;
}

/* 总结卡片 */
.conclusion-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #bbf7d0;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.conclusion-header {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.conclusion-icon {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #22c55e, #3b82f6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.conclusion-info {
  flex: 1;
}

.conclusion-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.conclusion-desc {
  font-size: 26rpx;
  color: #6b7280;
}

.conclusion-content {
  padding: 24rpx;
  background: linear-gradient(135deg, #f0fdf4, #eff6ff);
  border-radius: 16rpx;
  border: 4rpx solid #86efac;
  margin-bottom: 24rpx;
}

.conclusion-text {
  font-size: 30rpx;
  font-weight: 700;
  color: #111827;
  text-align: center;
}

.conclusion-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.conclusion-item {
  display: flex;
  align-items: flex-start;
}

.item-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.item-green {
  background: #dcfce7;
  color: #16a34a;
}

.item-blue {
  background: #dbeafe;
  color: #2563eb;
}

.item-purple {
  background: #f3e8ff;
  color: #9333ea;
}

.item-orange {
  background: #ffedd5;
  color: #ea580c;
}

.item-content {
  flex: 1;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.item-title {
  font-weight: 600;
  color: #111827;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: white;
  border-top: 2rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}
