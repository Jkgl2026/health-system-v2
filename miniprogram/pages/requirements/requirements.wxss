/* pages/requirements/requirements.wxss */
/* 四个要求详细任务页样式 - Web版精确复刻 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #eff6ff 0%, #ffffff 50%, #f0fdf4 100%);
  padding-bottom: 120rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-right {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.badge {
  padding: 8rpx 20rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.badge-outline {
  border: 2rpx solid #d1d5db;
  color: #374151;
}

.badge-primary {
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
}

.badge-secondary {
  background: #f3f4f6;
  color: #6b7280;
}

/* Tab导航 */
.tab-nav {
  display: flex;
  justify-content: center;
  padding: 24rpx 16rpx;
  background: white;
  border-bottom: 2rpx solid #e5e7eb;
  gap: 8rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 16rpx 24rpx;
  border-radius: 16rpx;
  position: relative;
  transition: all 0.3s ease;
  min-width: 140rpx;
}

.tab-item.active {
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  box-shadow: 0 4rpx 16rpx rgba(59, 130, 246, 0.3);
  transform: scale(1.05);
}

.tab-item.disabled {
  opacity: 0.5;
}

.tab-icon {
  font-size: 32rpx;
  margin-bottom: 4rpx;
}

.tab-label {
  font-size: 24rpx;
  font-weight: 600;
}

.tab-check {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 36rpx;
  height: 36rpx;
  background: #22c55e;
  border-radius: 50%;
  color: white;
  font-size: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.tab-lock {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  font-size: 20rpx;
}

/* 页面内容 */
.page-content {
  padding: 24rpx;
}

/* 卡片 */
.card {
  background: white;
  border-radius: 24rpx;
  border: 2rpx solid #e5e7eb;
  margin-bottom: 24rpx;
  overflow: hidden;
}

.card-main {
  border-width: 4rpx;
  border-color: #bfdbfe;
}

.card-section {
  border-width: 4rpx;
}

.card-header {
  padding: 32rpx;
  border-bottom: 2rpx solid #f3f4f6;
}

.card-title-main {
  text-align: center;
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.card-desc {
  text-align: center;
  font-size: 30rpx;
  color: #6b7280;
}

.card-title-section {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 8rpx;
}

.card-desc-section {
  font-size: 28rpx;
  color: #6b7280;
}

.card-body {
  padding: 32rpx;
}

/* 要求头部行 */
.req-header-row {
  display: flex;
  align-items: flex-start;
}

.req-number {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  font-weight: 700;
  color: white;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.req1-number {
  background: linear-gradient(135deg, #3b82f6, #22c55e);
}

.req2-number {
  background: linear-gradient(135deg, #a855f7, #ec4899);
}

.req3-number {
  background: linear-gradient(135deg, #22c55e, #14b8a6);
}

.req4-number {
  background: linear-gradient(135deg, #f97316, #ef4444);
}

.req-header-info {
  flex: 1;
}

/* 警告框 */
.alert {
  display: flex;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid;
}

.alert-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.alert-content {
  flex: 1;
}

.alert-title {
  font-weight: 600;
  display: block;
  margin-bottom: 8rpx;
}

.alert-text {
  font-size: 26rpx;
  line-height: 1.6;
}

.alert-highlight {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  margin-top: 12rpx;
}

.alert-danger {
  background: #fef2f2;
  border-color: #fca5a5;
}

.alert-danger .alert-title {
  color: #dc2626;
}

.alert-danger .alert-text {
  color: #991b1b;
}

.alert-danger .alert-highlight {
  color: #dc2626;
}

.alert-warning {
  background: #fffbeb;
  border-color: #fcd34d;
}

.alert-warning .alert-title {
  color: #d97706;
}

.alert-warning .alert-text {
  color: #92400e;
}

.alert-green {
  background: #f0fdf4;
  border-color: #86efac;
}

.alert-green .alert-title {
  color: #16a34a;
}

.alert-green .alert-text {
  color: #166534;
}

.alert-purple {
  background: #faf5ff;
  border-color: #d8b4fe;
}

.alert-purple .alert-title {
  color: #7c3aed;
}

.alert-purple .alert-text {
  color: #6b21a8;
}

.alert-orange {
  background: #fff7ed;
  border-color: #fdba74;
}

.alert-orange .alert-title {
  color: #ea580c;
}

.alert-orange .alert-text {
  color: #9a3412;
}

.alert-success {
  background: #f0fdf4;
  border-color: #86efac;
}

.alert-success .alert-title {
  color: #16a34a;
}

.alert-success .alert-text {
  color: #166534;
}

/* 信息框 */
.info-box {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid;
}

.info-title {
  font-weight: 600;
  font-size: 28rpx;
  margin-bottom: 16rpx;
}

.info-box.blue {
  background: #eff6ff;
  border-color: #93c5fd;
}

.info-box.blue .info-title {
  color: #1e40af;
}

.info-box.green {
  background: #f0fdf4;
  border-color: #86efac;
}

.info-box.green .info-title {
  color: #166534;
}

.info-box.orange {
  background: #fff7ed;
  border-color: #fdba74;
}

.info-box.orange .info-title {
  color: #9a3412;
}

.info-box.purple {
  background: #faf5ff;
  border-color: #d8b4fe;
}

.info-box.purple .info-title {
  color: #6b21a8;
}

.info-list {
  padding-left: 16rpx;
}

.info-item {
  font-size: 26rpx;
  line-height: 1.8;
  color: #374151;
}

/* 公式框 */
.formula-box {
  padding: 40rpx;
  background: linear-gradient(135deg, #eff6ff, #f0fdf4);
  border-radius: 16rpx;
  text-align: center;
  margin-bottom: 24rpx;
  border: 2rpx solid #bfdbfe;
}

.formula-text {
  font-size: 36rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.formula-tip {
  font-size: 28rpx;
  color: #374151;
  font-weight: 500;
  margin-top: 16rpx;
}

/* 要求概览 */
.requirement-overview-list {
  margin-bottom: 24rpx;
}

.requirement-overview-card {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid;
}

.req-overview-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.req-overview-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.req-overview-content {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.req1-bg {
  background: #eff6ff;
  border-color: #93c5fd;
}

.req2-bg {
  background: #faf5ff;
  border-color: #d8b4fe;
}

.req3-bg {
  background: #f0fdf4;
  border-color: #86efac;
}

.req4-bg {
  background: #fff7ed;
  border-color: #fdba74;
}

/* 清单部分 */
.checklist-section {
  margin-top: 24rpx;
}

.checklist-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.checklist-count {
  font-size: 28rpx;
  color: #6b7280;
}

.count-number {
  font-size: 36rpx;
  font-weight: 700;
  color: #3b82f6;
}

.count-number.purple {
  color: #a855f7;
}

.checklist-actions {
  display: flex;
  gap: 16rpx;
}

.btn-small {
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  border-radius: 12rpx;
  background: #f3f4f6;
  color: #374151;
}

.btn-small.purple {
  background: #faf5ff;
  color: #7c3aed;
}

/* 分类卡片 */
.category-card {
  background: white;
  border: 2rpx solid #e5e7eb;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  overflow: hidden;
}

.category-header {
  padding: 20rpx 24rpx;
  background: linear-gradient(90deg, #eff6ff, white);
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  border-bottom: 2rpx solid #f3f4f6;
}

.category-header.purple {
  background: linear-gradient(90deg, #faf5ff, white);
}

.category-items {
  padding: 16rpx;
}

/* 勾选项 */
.check-item {
  display: flex;
  padding: 16rpx;
  border-radius: 12rpx;
  margin-bottom: 8rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s ease;
}

.check-item.checked {
  background: #eff6ff;
  border-color: #bfdbfe;
}

.check-item.checked.purple {
  background: #faf5ff;
  border-color: #e9d5ff;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  font-size: 24rpx;
  color: white;
  background: white;
  flex-shrink: 0;
}

.checkbox.purple {
  border-color: #d8b4fe;
}

.check-item.checked .checkbox {
  background: #3b82f6;
  border-color: #3b82f6;
}

.check-item.checked.purple .checkbox {
  background: #a855f7;
  border-color: #a855f7;
}

.check-content {
  flex: 1;
}

.check-label {
  font-size: 26rpx;
  color: #111827;
  font-weight: 500;
  line-height: 1.6;
}

.check-impact {
  font-size: 22rpx;
  color: #dc2626;
  margin-top: 8rpx;
}

.check-desc {
  font-size: 22rpx;
  color: #7c3aed;
  margin-top: 8rpx;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: white;
  border-top: 2rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}

.btn-primary.disabled {
  background: #9ca3af;
}

.action-tip {
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 16rpx;
}
