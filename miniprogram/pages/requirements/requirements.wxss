/* pages/requirements/requirements.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; background: #fff; }
.header-title { font-size: 32rpx; font-weight: 600; }
.intro-section { padding: 32rpx; background: linear-gradient(135deg, #10b981, #059669); color: #fff; text-align: center; }
.intro-title { display: block; font-size: 32rpx; font-weight: 600; margin-bottom: 8rpx; }
.intro-desc { display: block; font-size: 24rpx; opacity: 0.9; }
.requirements-list { padding: 24rpx; }
.requirement-card { display: flex; align-items: center; gap: 16rpx; background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 16rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.req-icon { width: 72rpx; height: 72rpx; background: linear-gradient(135deg, #10b981, #059669); border-radius: 16rpx; display: flex; align-items: center; justify-content: center; font-size: 36rpx; flex-shrink: 0; }
.req-content { flex: 1; }
.req-title { display: block; font-size: 28rpx; font-weight: 600; color: #1f2937; margin-bottom: 8rpx; }
.req-desc { display: block; font-size: 24rpx; color: #6b7280; line-height: 1.4; }
.req-checkbox { width: 48rpx; height: 48rpx; border: 3rpx solid #d1d5db; border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
.req-checkbox.checked { background: #10b981; border-color: #10b981; }
.check-icon { color: #fff; font-size: 24rpx; font-weight: 700; }
.agree-section { display: flex; align-items: center; gap: 16rpx; padding: 24rpx; margin: 0 24rpx; background: #fff; border-radius: 16rpx; }
.agree-checkbox { width: 48rpx; height: 48rpx; border: 3rpx solid #10b981; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.agree-checkbox.checked { background: #10b981; }
.agree-text { font-size: 28rpx; color: #1f2937; }
.bottom-actions { display: flex; gap: 16rpx; padding: 24rpx; background: #fff; position: fixed; bottom: 0; left: 0; right: 0; }
.btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-primary[disabled] { opacity: 0.5; }
.btn-outline { background: #fff; border: 2rpx solid #e5e7eb; color: #6b7280; }
