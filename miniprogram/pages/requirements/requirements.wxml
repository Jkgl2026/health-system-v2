<!--pages/requirements/requirements.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack"><text class="back-icon">←</text><text>返回</text></view>
    <text class="header-title">四个要求</text>
    <text class="progress">3/4</text>
  </view>
  <view class="intro-section">
    <text class="intro-title">为了达到最好的调理效果</text>
    <text class="intro-desc">请您遵守以下要求</text>
  </view>
  <view class="requirements-list">
    <view wx:for="{{requirements}}" wx:key="id" class="requirement-card">
      <view class="req-icon">{{item.icon}}</view>
      <view class="req-content">
        <text class="req-title">{{item.title}}</text>
        <text class="req-desc">{{item.description}}</text>
      </view>
      <view class="req-checkbox {{agreed[index] ? 'checked' : ''}}" bindtap="toggleAgree" data-index="{{index}}">
        <text class="check-icon">{{agreed[index] ? '✓' : ''}}</text>
      </view>
    </view>
  </view>
  <view class="agree-section">
    <view class="agree-checkbox {{allAgreed ? 'checked' : ''}}" bindtap="toggleAllAgree">
      <text class="check-icon">{{allAgreed ? '✓' : ''}}</text>
    </view>
    <text class="agree-text">我已阅读并同意遵守以上四个要求</text>
  </view>
  <view class="bottom-actions">
    <button class="btn btn-outline" bindtap="goBack">上一步</button>
    <button class="btn btn-primary" bindtap="goNext" disabled="{{!allAgreed}}">下一步 →</button>
  </view>
</view>
