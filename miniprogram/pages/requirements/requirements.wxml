<!--pages/requirements/requirements.wxml-->
<view class="container">
  <!-- 顶部 -->
  <view class="header purple">
    <view class="header-content">
      <text class="header-title">四个要求</text>
      <text class="header-desc">健康管理的基本承诺</text>
    </view>
    <view class="header-icon">📋</view>
  </view>

  <!-- 要求列表 -->
  <scroll-view class="requirements-list" scroll-y>
    <view 
      wx:for="{{requirements}}" 
      wx:key="id"
      class="requirement-card {{item.selected ? 'has-selected' : ''}}"
    >
      <!-- 要求头部 -->
      <view class="req-header">
        <text class="req-icon">{{item.icon}}</text>
        <view class="req-title-wrap">
          <text class="req-title">{{item.title}}</text>
        </view>
      </view>

      <!-- 要求描述 -->
      <view class="req-desc">
        <text>{{item.desc}}</text>
      </view>

      <!-- 选项 -->
      <view class="req-options">
        <view 
          wx:for="{{item.options}}" 
          wx:for-item="option"
          wx:key="value"
          class="option {{item.selected === option.value ? 'selected' : ''}} {{option.value === 'agree' ? 'agree' : 'try'}}"
          data-req-id="{{item.id}}"
          data-value="{{option.value}}"
          bindtap="selectOption"
        >
          <view class="option-icon">
            <text wx:if="{{option.value === 'agree'}}">✓</text>
            <text wx:else>○</text>
          </view>
          <text class="option-text">{{option.label}}</text>
        </view>
      </view>
    </view>

    <!-- 快捷操作 -->
    <view class="quick-action" bindtap="agreeAll">
      <text class="quick-icon">⚡</text>
      <text class="quick-text">全部同意</text>
    </view>

    <!-- 查看故事 -->
    <view class="story-link" bindtap="onViewStory">
      <text class="story-icon">📖</text>
      <text class="story-text">了解"系统战役"故事</text>
      <text class="story-arrow">›</text>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn btn-primary" bindtap="onNext">
      查看健康方案
    </button>
  </view>
</view>
