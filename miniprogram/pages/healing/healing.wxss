/* pages/healing/healing.wxss */
/* 好转反应页面样式 - 1:1复刻Web版 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fef3c7 0%, #ffffff 50%, #dcfce7 100%);
  padding-bottom: 140rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-badge {
  padding: 8rpx 24rpx;
  border: 2rpx solid #fcd34d;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #92400e;
  background: #fef3c7;
}

/* 内容 */
.content {
  padding: 32rpx;
}

/* 标题卡片 */
.title-card {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #fcd34d;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.title-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #f59e0b, #ef4444);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx auto;
}

.title-text {
  font-size: 44rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.title-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 提示卡片 */
.notice-card {
  display: flex;
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid;
}

.notice-orange {
  background: #fff7ed;
  border-color: #fdba74;
}

.notice-red {
  background: #fef2f2;
  border-color: #fca5a5;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.notice-text {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.6;
}

.notice-orange .notice-title {
  color: #9a3412;
}

.notice-orange .notice-text {
  color: #7c2d12;
}

.notice-red .notice-title {
  color: #dc2626;
}

.notice-red .notice-text {
  color: #991b1b;
}

/* 故事卡片 */
.story-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #bfdbfe;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.story-content {
  background: linear-gradient(135deg, #eff6ff, #f0f9ff);
  padding: 32rpx;
  border-radius: 16rpx;
  border: 2rpx solid #bfdbfe;
}

.story-content text {
  display: block;
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  margin-bottom: 16rpx;
}

.story-content .highlight {
  font-weight: 600;
  color: #d97706;
}

/* 特点卡片 */
.feature-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #dcfce7;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.feature-item {
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
}

.feature-item:last-child {
  margin-bottom: 0;
}

.feature-green {
  background: #f0fdf4;
  border: 2rpx solid #86efac;
}

.feature-yellow {
  background: #fefce8;
  border: 2rpx solid #fde047;
}

.feature-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.feature-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.feature-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.feature-list {
  padding-left: 16rpx;
}

.feature-list-item {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

/* 应对方法卡片 */
.response-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #f3e8ff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.response-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.response-item {
  padding: 24rpx;
  border-radius: 16rpx;
}

.response-do {
  background: #f0fdf4;
  border: 2rpx solid #86efac;
}

.response-dont {
  background: #fef2f2;
  border: 2rpx solid #fecaca;
}

.response-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.response-list {
  padding-left: 8rpx;
}

.response-list-item {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.8;
  margin-bottom: 8rpx;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: white;
  border-top: 2rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}
