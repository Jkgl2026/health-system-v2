/* pages/healing/healing.wxss */
/* 好转反应页面样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fef3c7 0%, #ffffff 50%, #dcfce7 100%);
  padding-bottom: 120rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-badge {
  padding: 8rpx 24rpx;
  border: 2rpx solid #fcd34d;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #92400e;
  background: #fef3c7;
}

/* 内容 */
.content {
  padding: 32rpx;
}

/* 介绍卡片 */
.intro-card {
  background: white;
  border-radius: 24rpx;
  padding: 40rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #fcd34d;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.intro-title {
  text-align: center;
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.intro-desc {
  text-align: center;
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 故事卡片 */
.story-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e5e7eb;
}

.story-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

.story-content {
  font-size: 26rpx;
  color: #374151;
  line-height: 1.8;
}

.story-content text {
  display: block;
  margin-bottom: 16rpx;
}

.story-highlight {
  font-weight: 600;
  color: #d97706;
}

/* 反应部分 */
.reactions-section {
  margin-bottom: 24rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 20rpx;
}

.reaction-item {
  display: flex;
  align-items: flex-start;
  background: white;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 2rpx solid #e5e7eb;
}

.reaction-icon {
  width: 64rpx;
  height: 64rpx;
  background: #fef3c7;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-right: 20rpx;
}

.reaction-info {
  flex: 1;
}

.reaction-name {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.reaction-desc {
  font-size: 24rpx;
  color: #6b7280;
}

/* 提示卡片 */
.notice-card {
  background: #fef2f2;
  border-radius: 16rpx;
  padding: 24rpx;
  border: 2rpx solid #fca5a5;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #dc2626;
  margin-bottom: 12rpx;
}

.notice-content {
  font-size: 26rpx;
  color: #991b1b;
  line-height: 1.6;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: white;
  border-top: 2rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #f97316, #ef4444);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}
