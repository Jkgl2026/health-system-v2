<!--pages/admin-dashboard/admin-dashboard.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">后台管理</text>
    <text class="header-logout" bindtap="handleLogout">退出</text>
  </view>
  
  <!-- 统计卡片 -->
  <view class="stats">
    <view class="stat-card">
      <text class="stat-value">{{stats.totalUsers}}</text>
      <text class="stat-label">总用户</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.todayUsers}}</text>
      <text class="stat-label">今日新增</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.checkCount}}</text>
      <text class="stat-label">自检次数</text>
    </view>
    <view class="stat-card">
      <text class="stat-value">{{stats.avgScore}}</text>
      <text class="stat-label">平均分</text>
    </view>
  </view>
  
  <!-- 用户列表 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">用户列表</text>
      <text class="section-action" bindtap="refreshUsers">刷新</text>
    </view>
    
    <view class="user-list">
      <view class="user-item" wx:for="{{users}}" wx:key="_id" bindtap="viewUser" data-id="{{item._id}}">
        <view class="user-info">
          <text class="user-name">{{item.name || '未填写'}}</text>
          <text class="user-phone">{{item.phone || '未填写'}}</text>
        </view>
        <view class="user-meta">
          <text class="user-score">健康分: {{item.healthScore || '--'}}</text>
          <text class="user-time">{{item.createTime}}</text>
        </view>
      </view>
    </view>
    
    <view class="empty" wx:if="{{!users.length}}">
      <text class="empty-text">暂无用户数据</text>
    </view>
  </view>
  
  <!-- 数据管理 -->
  <view class="section">
    <view class="section-header">
      <text class="section-title">数据管理</text>
    </view>
    
    <view class="action-list">
      <button class="btn btn-secondary btn-block" bindtap="exportData">导出用户数据</button>
      <button class="btn btn-secondary btn-block" bindtap="clearAllData">清空所有数据</button>
    </view>
  </view>
</view>
