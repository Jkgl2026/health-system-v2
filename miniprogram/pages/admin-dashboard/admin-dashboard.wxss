/* pages/admin-dashboard/admin-dashboard.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.header { display: flex; justify-content: space-between; align-items: center; padding: 32rpx; background: linear-gradient(135deg, #1e3a5f, #0f172a); color: #fff; }
.header-title { font-size: 36rpx; font-weight: 700; }
.header-logout { font-size: 28rpx; color: #93c5fd; }
.stats { display: flex; gap: 16rpx; padding: 24rpx; }
.stat-card { flex: 1; padding: 24rpx; background: #fff; border-radius: 12rpx; text-align: center; }
.stat-value { display: block; font-size: 36rpx; font-weight: 700; color: #1f2937; }
.stat-label { display: block; font-size: 22rpx; color: #6b7280; margin-top: 4rpx; }
.section { margin: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: #1f2937; }
.section-action { font-size: 26rpx; color: #3b82f6; }
.user-list { display: flex; flex-direction: column; gap: 12rpx; }
.user-item { display: flex; justify-content: space-between; align-items: center; padding: 20rpx; background: #f9fafb; border-radius: 12rpx; }
.user-name { display: block; font-size: 28rpx; font-weight: 600; color: #1f2937; }
.user-phone { display: block; font-size: 24rpx; color: #6b7280; margin-top: 4rpx; }
.user-score { display: block; font-size: 24rpx; color: #10b981; }
.user-time { display: block; font-size: 22rpx; color: #9ca3af; margin-top: 4rpx; }
.empty { padding: 48rpx; text-align: center; }
.empty-text { font-size: 26rpx; color: #9ca3af; }
.action-list { display: flex; flex-direction: column; gap: 16rpx; }
.btn { display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 12rpx; font-size: 28rpx; }
.btn-secondary { background: #f3f4f6; color: #1f2937; }
.btn-block { width: 100%; }
