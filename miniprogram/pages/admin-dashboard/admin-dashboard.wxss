/* pages/admin-dashboard/admin-dashboard.wxss */
/* 后台管理仪表盘 - 增强版样式 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  padding-bottom: 100rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 30rpx;
  background: rgba(255, 255, 255, 0.1);
  backdrop-filter: blur(10px);
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
}

.header-actions {
  display: flex;
  gap: 20rpx;
}

.header-btn {
  padding: 12rpx 24rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 30rpx;
  color: #fff;
  font-size: 26rpx;
}

.header-btn.logout {
  background: rgba(239, 68, 68, 0.8);
}

/* 统计网格 - 四宫格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
  padding: 20rpx;
}

.stat-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  display: flex;
  flex-direction: column;
  position: relative;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.stat-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
}

.stat-card.blue::before { background: #3b82f6; }
.stat-card.green::before { background: #22c55e; }
.stat-card.purple::before { background: #8b5cf6; }
.stat-card.orange::before { background: #f97316; }

.stat-icon {
  font-size: 48rpx;
  margin-bottom: 10rpx;
}

.stat-content {
  display: flex;
  flex-direction: column;
}

.stat-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1f2937;
}

.stat-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

.stat-trend {
  position: absolute;
  top: 20rpx;
  right: 20rpx;
}

.trend-badge {
  background: #dcfce7;
  color: #16a34a;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 20rpx;
}

/* 区块样式 */
.section {
  margin: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.1);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #1f2937;
}

.section-subtitle {
  font-size: 24rpx;
  color: #6b7280;
}

.section-action {
  font-size: 26rpx;
  color: #3b82f6;
}

/* 健康要素分析 */
.health-elements {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.element-item {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.element-header {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.element-icon {
  font-size: 28rpx;
}

.element-name {
  font-size: 26rpx;
  color: #374151;
  flex: 1;
}

.element-value {
  font-size: 26rpx;
  font-weight: bold;
  color: #1f2937;
}

.element-bar {
  height: 12rpx;
  background: #e5e7eb;
  border-radius: 6rpx;
  overflow: hidden;
}

.element-fill {
  height: 100%;
  border-radius: 6rpx;
  transition: width 0.3s ease;
}

.fill-red { background: linear-gradient(90deg, #ef4444, #f87171); }
.fill-blue { background: linear-gradient(90deg, #3b82f6, #60a5fa); }
.fill-yellow { background: linear-gradient(90deg, #eab308, #facc15); }
.fill-orange { background: linear-gradient(90deg, #f97316, #fb923c); }
.fill-cyan { background: linear-gradient(90deg, #06b6d4, #22d3ee); }
.fill-green { background: linear-gradient(90deg, #22c55e, #4ade80); }
.fill-purple { background: linear-gradient(90deg, #8b5cf6, #a78bfa); }

/* 体质分布 */
.constitution-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 15rpx;
}

.constitution-item {
  background: #f9fafb;
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
}

.constitution-count {
  font-size: 36rpx;
  font-weight: bold;
  color: #3b82f6;
}

.constitution-name {
  font-size: 22rpx;
  color: #6b7280;
  margin-top: 4rpx;
}

/* 快捷操作 */
.quick-actions {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 15rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.action-item {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 10rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.action-icon {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
}

.action-icon.blue { background: #dbeafe; }
.action-icon.green { background: #dcfce7; }
.action-icon.purple { background: #ede9fe; }
.action-icon.red { background: #fee2e2; }

.action-name {
  font-size: 22rpx;
  color: #374151;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  gap: 15rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.search-input-wrapper {
  flex: 1;
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 40rpx;
  padding: 0 30rpx;
  box-shadow: 0 4rpx 15rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.search-input {
  flex: 1;
  height: 80rpx;
  font-size: 28rpx;
}

.search-clear {
  font-size: 28rpx;
  color: #9ca3af;
  padding: 10rpx;
}

.search-btn {
  background: #3b82f6;
  color: #fff;
  font-size: 28rpx;
  padding: 0 30rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  border: none;
}

/* 筛选标签 */
.filter-tabs {
  display: flex;
  gap: 15rpx;
  padding: 0 20rpx;
  margin-bottom: 20rpx;
}

.filter-tab {
  padding: 16rpx 30rpx;
  background: rgba(255, 255, 255, 0.3);
  border-radius: 30rpx;
  font-size: 26rpx;
  color: #fff;
}

.filter-tab.active {
  background: #fff;
  color: #3b82f6;
  font-weight: bold;
}

/* 用户列表 */
.user-list {
  display: flex;
  flex-direction: column;
  gap: 15rpx;
}

.user-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  background: #f9fafb;
  border-radius: 16rpx;
  padding: 20rpx;
}

.user-left {
  display: flex;
  align-items: flex-start;
  gap: 20rpx;
  flex: 1;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}

.user-info {
  flex: 1;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 15rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #1f2937;
}

.health-badge {
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  font-size: 20rpx;
  color: #fff;
}

.status-excellent { background: #22c55e; }
.status-good { background: #3b82f6; }
.status-normal { background: #eab308; }
.status-warning { background: #f97316; }
.status-danger { background: #ef4444; }

.user-meta {
  display: flex;
  gap: 20rpx;
  margin-bottom: 10rpx;
}

.meta-phone, .meta-time {
  font-size: 22rpx;
  color: #6b7280;
}

.user-scores {
  display: flex;
  gap: 20rpx;
}

.score-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
}

.score-label {
  font-size: 20rpx;
  color: #9ca3af;
}

.score-value {
  font-size: 24rpx;
  font-weight: bold;
  color: #374151;
}

.user-action {
  padding: 20rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #9ca3af;
}

/* 加载更多 */
.load-more {
  padding: 30rpx;
  text-align: center;
}

.load-more-text {
  font-size: 26rpx;
  color: #3b82f6;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #6b7280;
}

.empty-hint {
  font-size: 24rpx;
  color: #9ca3af;
  margin-top: 10rpx;
}

/* 底部 */
.footer {
  text-align: center;
  padding: 40rpx;
}

.footer-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
}
