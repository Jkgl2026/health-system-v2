/* pages/admin-dashboard/admin-dashboard.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
  padding-bottom: 40rpx;
}

/* 顶部导航 */
.header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
}

.header-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #ffffff;
}

.header-actions {
  display: flex;
  gap: 16rpx;
}

.header-btn {
  font-size: 26rpx;
  color: #ffffff;
  padding: 10rpx 20rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 20rpx;
}

.header-btn.logout {
  background: rgba(239, 68, 68, 0.2);
}

/* 统计概览 */
.stats-overview {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  padding: 24rpx;
  margin-top: -10rpx;
}

.stat-card {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stat-card.primary {
  background: linear-gradient(135deg, #ffffff 0%, #eff6ff 100%);
}

.stat-card.success {
  background: linear-gradient(135deg, #ffffff 0%, #f0fdf4 100%);
}

.stat-icon {
  font-size: 48rpx;
}

.stat-info {
  flex: 1;
}

.stat-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
}

.stat-label {
  font-size: 24rpx;
  color: #64748b;
  display: block;
  margin-top: 4rpx;
}

.stat-trend {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 8rpx 12rpx;
  border-radius: 12rpx;
}

.stat-trend.positive {
  background: rgba(34, 197, 94, 0.1);
}

.trend-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #22c55e;
}

.trend-label {
  font-size: 20rpx;
  color: #64748b;
}

/* 快捷操作 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 16rpx 24rpx;
  background: #ffffff;
  margin: 0 24rpx;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  padding: 16rpx 32rpx;
}

.action-icon {
  font-size: 40rpx;
}

.action-name {
  font-size: 24rpx;
  color: #475569;
}

/* 搜索栏 */
.search-bar {
  padding: 16rpx 24rpx;
}

.search-input-wrapper {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  background: #ffffff;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.search-icon {
  font-size: 32rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1e293b;
}

/* 区块 */
.section {
  padding: 0 24rpx;
  margin-top: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.section-action {
  font-size: 26rpx;
  color: #3b82f6;
}

/* 用户列表 */
.user-list {
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.user-item {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border-bottom: 1rpx solid #f1f5f9;
  transition: background 0.2s;
}

.user-item:last-child {
  border-bottom: none;
}

.user-item:active {
  background: #f8fafc;
}

.user-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 32rpx;
  color: #ffffff;
  font-weight: 600;
}

.user-main {
  flex: 1;
  min-width: 0;
}

.user-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1e293b;
}

.user-phone {
  font-size: 24rpx;
  color: #64748b;
  padding: 4rpx 12rpx;
  background: #f1f5f9;
  border-radius: 10rpx;
}

.user-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  gap: 4rpx;
}

.meta-icon {
  font-size: 22rpx;
}

.meta-label {
  font-size: 22rpx;
  color: #94a3b8;
}

.meta-value {
  font-size: 24rpx;
  color: #1e293b;
  font-weight: 500;
}

.meta-value.good {
  color: #22c55e;
}

.meta-value.warning {
  color: #f97316;
}

.meta-value.time {
  font-size: 22rpx;
  color: #94a3b8;
  font-weight: 400;
}

.user-action {
  padding: 12rpx;
}

.action-arrow {
  font-size: 32rpx;
  color: #cbd5e1;
}

/* 加载更多 */
.load-more {
  padding: 24rpx;
  text-align: center;
  background: #ffffff;
  border-radius: 0 0 16rpx 16rpx;
}

.load-more-text {
  font-size: 26rpx;
  color: #3b82f6;
}

/* 空状态 */
.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
  background: #ffffff;
  border-radius: 16rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #94a3b8;
}
