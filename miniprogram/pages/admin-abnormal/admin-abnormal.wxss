/* pages/admin-abnormal/admin-abnormal.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #f8fafc 0%, #f1f5f9 100%);
}

/* 顶部导航 */
.header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 12rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
  position: sticky;
  top: 0;
  z-index: 100;
}

.header-back {
  font-size: 28rpx;
  color: #3b82f6;
  padding: 12rpx 20rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #1e293b;
}

.header-action {
  width: 100rpx;
}

/* 筛选栏 */
.filter-bar {
  display: flex;
  padding: 20rpx 24rpx;
  background: #ffffff;
  border-bottom: 1rpx solid #e2e8f0;
}

.filter-picker {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fef2f2;
  border-radius: 12rpx;
  border: 1rpx solid #fecaca;
}

.filter-label {
  font-size: 26rpx;
  color: #64748b;
  margin-right: 12rpx;
}

.filter-value {
  font-size: 26rpx;
  color: #ef4444;
  font-weight: 500;
}

.filter-arrow {
  font-size: 20rpx;
  color: #ef4444;
  margin-left: 12rpx;
}

/* 统计卡片 */
.stats-cards {
  display: flex;
  padding: 24rpx;
  gap: 20rpx;
}

.stats-card {
  flex: 1;
  background: #ffffff;
  border-radius: 16rpx;
  padding: 24rpx;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.stats-card.warning {
  background: linear-gradient(135deg, #fef2f2 0%, #fee2e2 100%);
}

.stats-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1e293b;
  display: block;
}

.stats-card.warning .stats-value {
  color: #ef4444;
}

.stats-label {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
  display: block;
}

/* 用户列表 */
.user-list {
  margin: 0 24rpx;
  background: #ffffff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.05);
}

.list-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.list-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #1e293b;
}

.list-count {
  font-size: 24rpx;
  color: #64748b;
}

/* 用户项 */
.user-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #f1f5f9;
}

.user-item:last-child {
  border-bottom: none;
}

.user-info {
  display: flex;
  align-items: center;
  flex: 1;
}

.user-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
}

.avatar-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #ffffff;
}

.user-detail {
  flex: 1;
}

.user-name {
  font-size: 30rpx;
  font-weight: 500;
  color: #1e293b;
  display: block;
}

.user-meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}

.meta-item {
  font-size: 24rpx;
  color: #64748b;
}

.meta-divider {
  margin: 0 12rpx;
  color: #cbd5e1;
}

.user-time {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 6rpx;
  display: block;
}

/* 健康分 */
.user-score {
  margin-left: 20rpx;
}

.score-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 4rpx solid;
  display: flex;
  align-items: center;
  justify-content: center;
}

.score-value {
  font-size: 28rpx;
  font-weight: 700;
}

/* 加载中 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #e2e8f0;
  border-top-color: #ef4444;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: #64748b;
}

/* 加载更多 */
.load-more {
  padding: 30rpx;
  text-align: center;
}

.load-more-text {
  font-size: 26rpx;
  color: #64748b;
}

/* 没有更多 */
.no-more {
  padding: 30rpx;
  text-align: center;
}

.no-more-text {
  font-size: 24rpx;
  color: #94a3b8;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #64748b;
}
