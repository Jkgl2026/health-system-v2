<!--pages/admin-abnormal/admin-abnormal.wxml-->
<view class="container">
  <!-- 顶部导航 -->
  <view class="header">
    <text class="header-back" bindtap="goBack">← 返回</text>
    <text class="header-title">异常用户</text>
    <text class="header-action"></text>
  </view>

  <!-- 筛选栏 -->
  <view class="filter-bar">
    <picker mode="selector" range="{{thresholdOptions}}" range-key="" value="{{thresholdOptions.indexOf(scoreThreshold)}}" bindchange="onThresholdChange">
      <view class="filter-picker">
        <text class="filter-label">健康分阈值:</text>
        <text class="filter-value">{{scoreThreshold}}分以下</text>
        <text class="filter-arrow">▼</text>
      </view>
    </picker>
  </view>

  <!-- 统计卡片 -->
  <view class="stats-cards">
    <view class="stats-card warning">
      <text class="stats-value">{{stats.totalAbnormal}}</text>
      <text class="stats-label">异常用户数</text>
    </view>
    <view class="stats-card">
      <text class="stats-value">{{stats.avgScore}}</text>
      <text class="stats-label">平均健康分</text>
    </view>
  </view>

  <!-- 用户列表 -->
  <view class="user-list">
    <view class="list-header">
      <text class="list-title">异常用户列表</text>
      <text class="list-count">共{{total}}人</text>
    </view>

    <!-- 加载中 -->
    <view class="loading-container" wx:if="{{loading && users.length === 0}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 用户项 -->
    <view class="user-item" wx:for="{{users}}" wx:key="id" data-id="{{item.id}}" bindtap="viewUser">
      <view class="user-info">
        <view class="user-avatar" style="background: {{item.scoreColor}};">
          <text class="avatar-text">{{item.name[0] || '?'}}</text>
        </view>
        <view class="user-detail">
          <text class="user-name">{{item.name}}</text>
          <view class="user-meta">
            <text class="meta-item">{{item.phone}}</text>
            <text class="meta-divider" wx:if="{{item.phone && item.gender}}">|</text>
            <text class="meta-item">{{item.gender}}</text>
            <text class="meta-divider" wx:if="{{item.gender && item.age}}">|</text>
            <text class="meta-item">{{item.age}}岁</text>
          </view>
          <text class="user-time">最近检测: {{item.lastRecordTimeStr}}</text>
        </view>
      </view>
      <view class="user-score">
        <view class="score-circle" style="border-color: {{item.scoreColor}};">
          <text class="score-value" style="color: {{item.scoreColor}};">{{item.healthScore}}</text>
        </view>
      </view>
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{loading && users.length > 0}}">
      <text class="load-more-text">加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{!hasMore && users.length > 0}}">
      <text class="no-more-text">已加载全部</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && users.length === 0}}">
      <text class="empty-icon">✅</text>
      <text class="empty-text">暂无异常用户</text>
    </view>
  </view>
</view>
