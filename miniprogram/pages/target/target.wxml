<!--pages/target/target.wxml-->
<view class="container">
  <view class="header">
    <view class="back-btn" bindtap="goBack"><text class="back-icon">←</text><text>返回</text></view>
    <text class="header-title">重点症状选择</text>
    <text class="progress-info">{{selectedCount}}/3</text>
  </view>
  <view class="tip-section">
    <text class="tip-icon">💡</text>
    <text class="tip-text">请从已选症状中选择3个最困扰您的症状</text>
  </view>
  <view class="selected-all">
    <text class="section-title">您已选中的症状（{{allSymptoms.length}}项）</text>
    <view class="symptom-grid">
      <view wx:for="{{allSymptoms}}" wx:key="id" class="symptom-item {{selectedIds.includes(item.id) ? 'selected' : ''}}" bindtap="toggleSymptom" data-id="{{item.id}">
        <text class="symptom-name">{{item.name}}</text>
        <text class="symptom-category">{{item.category}}</text>
        <view wx:if="{{selectedIds.includes(item.id)}}" class="check-mark">✓</view>
      </view>
    </view>
  </view>
  <view class="selected-summary">
    <text class="summary-title">已选重点症状：</text>
    <view class="selected-list">
      <view wx:for="{{selectedSymptoms}}" wx:key="id" class="selected-item">
        <text class="selected-index">{{index + 1}}</text>
        <text class="selected-name">{{item.name}}</text>
      </view>
    </view>
  </view>
  <view class="bottom-actions">
    <button class="btn btn-outline" bindtap="goBack">上一步</button>
    <button class="btn btn-primary" bindtap="goNext" disabled="{{selectedCount !== 3}}">下一步 →</button>
  </view>
</view>
