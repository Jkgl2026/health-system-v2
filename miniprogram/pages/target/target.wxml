<!--pages/target/target.wxml-->
<view class="container">
  <!-- 顶部 -->
  <view class="header red">
    <view class="header-content">
      <text class="header-title">选择重点症状</text>
      <text class="header-desc">从您的症状中选择最困扰的3个</text>
    </view>
    <view class="selected-count">
      <text class="count-num">{{targetSymptoms.length}}</text>
      <text class="count-label">/3个</text>
    </view>
  </view>

  <!-- 提示 -->
  <view class="tip">
    <text class="tip-icon">💡</text>
    <text class="tip-text">重点症状将作为您改善健康的优先目标</text>
  </view>

  <!-- 症状列表 -->
  <scroll-view class="symptom-list" scroll-y>
    <view 
      wx:for="{{allSymptoms}}" 
      wx:key="id"
      class="symptom-item {{targetSymptoms.indexOf(item.id) > -1 ? 'selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="toggleTarget"
    >
      <view class="checkbox {{targetSymptoms.indexOf(item.id) > -1 ? 'checked' : ''}}">
        <text wx:if="{{targetSymptoms.indexOf(item.id) > -1}}">✓</text>
      </view>
      <view class="symptom-content">
        <text class="symptom-name">{{item.name}}</text>
        <text class="symptom-source">{{item.source}}</text>
      </view>
    </view>

    <view wx:if="{{allSymptoms.length === 0}}" class="empty">
      <text class="empty-icon">📋</text>
      <text class="empty-text">暂无症状数据</text>
      <text class="empty-desc">请先完成身体语言简表或300症状表</text>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn btn-secondary" bindtap="onSkip">跳过</button>
    <button class="btn btn-primary" bindtap="onNext">下一步</button>
  </view>
</view>
