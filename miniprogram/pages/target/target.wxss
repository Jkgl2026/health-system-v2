/* pages/target/target.wxss */
.container {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
  background: #f5f5f5;
}

.header {
  padding: 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header.red {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: white;
}

.header-content {
  flex: 1;
}

.header-title {
  font-size: 36rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 10rpx;
}

.header-desc {
  font-size: 28rpx;
  opacity: 0.9;
}

.selected-count {
  display: flex;
  align-items: baseline;
  padding: 15rpx 25rpx;
  background: rgba(255,255,255,0.2);
  border-radius: 30rpx;
}

.count-num {
  font-size: 40rpx;
  font-weight: bold;
}

.count-label {
  font-size: 24rpx;
  margin-left: 5rpx;
  opacity: 0.8;
}

.tip {
  display: flex;
  align-items: center;
  padding: 20rpx 30rpx;
  background: #fff3cd;
  margin: 20rpx;
  border-radius: 12rpx;
}

.tip-icon {
  font-size: 32rpx;
  margin-right: 15rpx;
}

.tip-text {
  font-size: 26rpx;
  color: #856404;
}

.symptom-list {
  flex: 1;
  padding: 0 20rpx;
  max-height: calc(100vh - 350rpx);
}

.symptom-item {
  display: flex;
  align-items: center;
  background: white;
  padding: 25rpx;
  margin-bottom: 15rpx;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
  transition: all 0.2s;
}

.symptom-item.selected {
  border: 2rpx solid #ff6b6b;
  background: #fff5f5;
}

.checkbox {
  width: 44rpx;
  height: 44rpx;
  border: 2rpx solid #ddd;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  font-size: 24rpx;
  color: white;
  transition: all 0.2s;
}

.checkbox.checked {
  background: #ff6b6b;
  border-color: #ff6b6b;
}

.symptom-content {
  flex: 1;
}

.symptom-name {
  display: block;
  font-size: 30rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.symptom-source {
  font-size: 24rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 100rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
}

.bottom-bar {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 30rpx;
  background: white;
  box-shadow: 0 -2rpx 10rpx rgba(0,0,0,0.05);
}

.btn {
  flex: 1;
  height: 88rpx;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: bold;
}

.btn-primary {
  background: linear-gradient(135deg, #ff6b6b, #ee5a24);
  color: white;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666;
}
