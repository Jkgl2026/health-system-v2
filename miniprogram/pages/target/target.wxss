/* pages/target/target.wxss */
.container { min-height: 100vh; background: #f5f5f5; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; background: #fff; }
.header-title { font-size: 32rpx; font-weight: 600; }
.progress-info { background: #ef4444; color: #fff; padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; }
.tip-section { display: flex; align-items: center; gap: 12rpx; padding: 16rpx 24rpx; background: #fef3c7; margin: 16rpx 24rpx; border-radius: 12rpx; }
.selected-all { margin: 16rpx 24rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; }
.section-title { display: block; font-size: 28rpx; font-weight: 600; color: #1f2937; margin-bottom: 16rpx; }
.symptom-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16rpx; }
.symptom-item { position: relative; padding: 20rpx; background: #f9fafb; border: 2rpx solid #e5e7eb; border-radius: 12rpx; text-align: center; }
.symptom-item.selected { background: #fef2f2; border-color: #ef4444; }
.symptom-name { display: block; font-size: 26rpx; color: #1f2937; margin-bottom: 4rpx; }
.symptom-category { display: block; font-size: 20rpx; color: #9ca3af; }
.check-mark { position: absolute; top: 8rpx; right: 8rpx; width: 32rpx; height: 32rpx; background: #ef4444; color: #fff; border-radius: 50%; font-size: 20rpx; display: flex; align-items: center; justify-content: center; }
.selected-summary { margin: 16rpx 24rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; }
.selected-list { display: flex; flex-direction: column; gap: 12rpx; margin-top: 12rpx; }
.selected-item { display: flex; align-items: center; gap: 12rpx; }
.selected-index { width: 40rpx; height: 40rpx; background: #ef4444; color: #fff; border-radius: 50%; font-size: 24rpx; display: flex; align-items: center; justify-content: center; }
.selected-name { font-size: 28rpx; color: #1f2937; }
.bottom-actions { display: flex; gap: 16rpx; padding: 24rpx; background: #fff; position: fixed; bottom: 0; left: 0; right: 0; }
.btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-primary[disabled] { opacity: 0.5; }
.btn-outline { background: #fff; border: 2rpx solid #e5e7eb; color: #6b7280; }
