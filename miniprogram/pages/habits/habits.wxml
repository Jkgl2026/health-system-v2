<!--pages/habits/habits.wxml-->
<!--不良生活习惯页 - 252项习惯分类展示-->

<view class="container">
  <!-- 头部 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
      <text>返回</text>
    </view>
    <text class="header-title">不良生活习惯</text>
    <view class="progress-info">{{selectedCount}}/252</view>
  </view>

  <!-- 进度条 -->
  <view class="progress-bar-container">
    <view class="progress-bar">
      <view class="progress-fill" style="width: {{progress}}%;"></view>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-section">
    <view class="search-bar">
      <text class="search-icon">🔍</text>
      <input class="search-input" placeholder="搜索习惯..." value="{{searchQuery}}" bindinput="onSearch" />
    </view>
  </view>

  <!-- 分类标签 -->
  <scroll-view class="category-scroll" scroll-x>
    <view class="category-list">
      <view class="category-item {{currentCategory === 'all' ? 'active' : ''}}" bindtap="selectCategory" data-category="all">全部</view>
      <view wx:for="{{categories}}" wx:key="*this" class="category-item {{currentCategory === item ? 'active' : ''}}" bindtap="selectCategory" data-category="{{item}}">{{item}}</view>
    </view>
  </scroll-view>

  <!-- 习惯列表 -->
  <scroll-view class="habit-list" scroll-y>
    <view wx:for="{{filteredHabits}}" wx:key="id" class="habit-item">
      <view class="habit-checkbox {{selectedIds.includes(item.id) ? 'checked' : ''}}" bindtap="toggleHabit" data-id="{{item.id}}">
        <text class="checkbox-icon">{{selectedIds.includes(item.id) ? '✓' : ''}}</text>
      </view>
      <view class="habit-content">
        <text class="habit-name">{{item.habit}}</text>
        <text class="habit-impact">{{item.impact}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 已选统计 -->
  <view class="selected-summary">
    <view class="summary-header">
      <text class="summary-icon">📋</text>
      <text class="summary-title">已选习惯 ({{selectedCount}}项)</text>
    </view>
    <view wx:if="{{selectedCount > 0}}" class="count-badge">{{selectedCount}}</view>
  </view>

  <!-- 底部按钮 -->
  <view class="bottom-actions">
    <button class="btn btn-outline" bindtap="goBack">上一步</button>
    <button class="btn btn-primary" bindtap="goNext">下一步 →</button>
  </view>
</view>
