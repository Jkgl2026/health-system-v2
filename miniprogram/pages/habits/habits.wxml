<!--pages/habits/habits.wxml-->
<view class="container">
  <!-- 顶部 -->
  <view class="header">
    <view class="header-content">
      <text class="header-title">不良生活习惯</text>
      <text class="header-desc">请勾选您的不良生活习惯（252项）</text>
    </view>
    <view class="selected-count">
      <text class="count-num">{{selectedHabits.length}}</text>
      <text class="count-label">项已选</text>
    </view>
  </view>

  <!-- 搜索框 -->
  <view class="search-bar">
    <input 
      class="search-input" 
      placeholder="搜索习惯..."
      value="{{searchKeyword}}"
      bindinput="onSearch"
    />
  </view>

  <!-- 分类标签 -->
  <scroll-view wx:if="{{!isSearching}}" class="category-tabs" scroll-x enable-flex>
    <view 
      wx:for="{{categories}}" 
      wx:key="index"
      class="tab-item {{currentCategory === index ? 'active' : ''}}"
      data-index="{{index}}"
      bindtap="onCategoryChange"
    >
      <text>{{item}}</text>
    </view>
  </scroll-view>

  <!-- 操作按钮 -->
  <view class="action-bar">
    <button class="btn-small btn-outline" bindtap="selectAll">全选</button>
    <button class="btn-small btn-outline" bindtap="clearCurrent">清空</button>
  </view>

  <!-- 习惯列表 -->
  <scroll-view class="habit-list" scroll-y>
    <view 
      wx:for="{{filteredHabits}}" 
      wx:key="id"
      class="habit-item {{selectedHabits.indexOf(item.id) > -1 ? 'selected' : ''}}"
      data-id="{{item.id}}"
      bindtap="toggleHabit"
    >
      <view class="checkbox {{selectedHabits.indexOf(item.id) > -1 ? 'checked' : ''}}">
        <text wx:if="{{selectedHabits.indexOf(item.id) > -1}}">✓</text>
      </view>
      <view class="habit-content">
        <text class="habit-name">{{item.habit}}</text>
        <text class="habit-impact">{{item.impact}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 底部按钮 -->
  <view class="bottom-bar">
    <button class="btn btn-secondary" bindtap="onSkip">跳过</button>
    <button class="btn btn-primary" bindtap="onNext">下一步</button>
  </view>
</view>
