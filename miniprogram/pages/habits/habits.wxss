/* pages/habits/habits.wxss */
.container { min-height: 100vh; background: #f5f5f5; display: flex; flex-direction: column; }
.header { display: flex; align-items: center; justify-content: space-between; padding: 24rpx 32rpx; background: #fff; border-bottom: 1rpx solid #e5e7eb; }
.back-btn { display: flex; align-items: center; gap: 8rpx; color: #6b7280; font-size: 28rpx; }
.header-title { font-size: 32rpx; font-weight: 600; color: #1f2937; }
.progress-info { background: #f97316; color: #fff; padding: 8rpx 16rpx; border-radius: 20rpx; font-size: 24rpx; }
.progress-bar-container { padding: 16rpx 32rpx; background: #fff; }
.progress-bar { height: 8rpx; background: #e5e7eb; border-radius: 4rpx; overflow: hidden; }
.progress-fill { height: 100%; background: linear-gradient(90deg, #f97316, #ef4444); border-radius: 4rpx; transition: width 0.3s; }
.search-section { padding: 16rpx 24rpx; background: #fff; }
.search-bar { display: flex; align-items: center; background: #f3f4f6; border-radius: 24rpx; padding: 16rpx 24rpx; }
.search-input { flex: 1; font-size: 28rpx; margin-left: 12rpx; }
.category-scroll { background: #fff; white-space: nowrap; border-bottom: 1rpx solid #e5e7eb; }
.category-list { display: inline-flex; padding: 16rpx 24rpx; gap: 16rpx; }
.category-item { padding: 12rpx 24rpx; background: #f3f4f6; border-radius: 20rpx; font-size: 26rpx; color: #6b7280; flex-shrink: 0; }
.category-item.active { background: #f97316; color: #fff; }
.habit-list { flex: 1; padding: 16rpx 24rpx; background: #fff; margin: 0 24rpx; border-radius: 16rpx; max-height: 600rpx; }
.habit-item { display: flex; align-items: flex-start; padding: 20rpx 0; border-bottom: 1rpx solid #f3f4f6; }
.habit-checkbox { width: 48rpx; height: 48rpx; border: 3rpx solid #d1d5db; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; margin-right: 16rpx; flex-shrink: 0; }
.habit-checkbox.checked { background: #f97316; border-color: #f97316; }
.checkbox-icon { color: #fff; font-size: 24rpx; font-weight: 700; }
.habit-content { flex: 1; }
.habit-name { display: block; font-size: 28rpx; color: #1f2937; margin-bottom: 8rpx; }
.habit-impact { display: block; font-size: 22rpx; color: #9ca3af; line-height: 1.4; }
.selected-summary { margin: 16rpx 24rpx; padding: 20rpx; background: #fff; border-radius: 16rpx; display: flex; align-items: center; justify-content: space-between; }
.summary-header { display: flex; align-items: center; gap: 12rpx; }
.count-badge { background: #f97316; color: #fff; padding: 8rpx 20rpx; border-radius: 20rpx; font-size: 24rpx; font-weight: 600; }
.bottom-actions { display: flex; gap: 16rpx; padding: 24rpx; background: #fff; border-top: 1rpx solid #e5e7eb; }
.btn { flex: 1; display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; font-weight: 500; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-outline { background: #fff; border: 2rpx solid #e5e7eb; color: #6b7280; }
