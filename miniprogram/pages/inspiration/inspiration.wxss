/* pages/inspiration/inspiration.wxss */
/* 发心感悟页面样式 - 1:1复刻Web版 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #fef3c7 0%, #ffffff 50%, #dcfce7 100%);
  padding-bottom: 140rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-badge {
  padding: 8rpx 24rpx;
  border: 2rpx solid #f472b6;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #be185d;
  background: #fce7f3;
}

/* 内容 */
.content {
  padding: 32rpx;
}

/* 标题卡片 */
.title-card {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #f472b6;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.title-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #ec4899, #f43f5e);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx auto;
}

.title-text {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.title-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 内容卡片 */
.content-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #f3e8ff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.quote-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.content-box {
  padding: 32rpx;
  background: linear-gradient(135deg, #faf5ff, #fdf2f8);
  border-radius: 16rpx;
  border: 4rpx solid #e9d5ff;
}

.content-text {
  font-size: 28rpx;
  color: #374151;
  line-height: 2;
  text-align: center;
  white-space: pre-line;
}

/* 健康理念卡片 */
.philosophy-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #bfdbfe;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.philosophy-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.philosophy-item {
  padding: 24rpx;
  border-radius: 16rpx;
  border: 2rpx solid;
}

.philosophy-blue {
  background: #eff6ff;
  border-color: #93c5fd;
}

.philosophy-green {
  background: #f0fdf4;
  border-color: #86efac;
}

.philosophy-orange {
  background: #fff7ed;
  border-color: #fdba74;
}

.philosophy-purple {
  background: #faf5ff;
  border-color: #c4b5fd;
}

.philosophy-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  margin-bottom: 12rpx;
}

.philosophy-blue .philosophy-icon {
  background: #3b82f6;
}

.philosophy-green .philosophy-icon {
  background: #22c55e;
}

.philosophy-orange .philosophy-icon {
  background: #f97316;
}

.philosophy-purple .philosophy-icon {
  background: #a855f7;
}

.philosophy-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.philosophy-desc {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 行动承诺卡片 */
.promise-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #fef08a;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.promise-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.promise-item {
  display: flex;
  padding: 20rpx;
  border-radius: 12rpx;
  border: 2rpx solid;
}

.promise-yellow {
  background: #fefce8;
  border-color: #fde047;
}

.promise-blue {
  background: #eff6ff;
  border-color: #93c5fd;
}

.promise-green {
  background: #f0fdf4;
  border-color: #86efac;
}

.promise-num {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 700;
  color: white;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.promise-yellow .promise-num {
  background: #eab308;
}

.promise-blue .promise-num {
  background: #3b82f6;
}

.promise-green .promise-num {
  background: #22c55e;
}

.promise-content {
  flex: 1;
}

.promise-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.promise-desc {
  font-size: 22rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 底部操作 */
.bottom-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx;
  background: white;
  border-top: 2rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.btn-primary {
  width: 100%;
  padding: 28rpx;
  background: linear-gradient(135deg, #3b82f6, #22c55e);
  color: white;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
  text-align: center;
}
