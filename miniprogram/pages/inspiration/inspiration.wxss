/* pages/inspiration/inspiration.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #F0F9FF 0%, #FFFFFF 100%);
  display: flex;
  flex-direction: column;
}

/* 头部导航 */
.header {
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1rpx solid #E5E7EB;
  position: sticky;
  top: 0;
  z-index: 100;
}

.back-btn {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
  color: #3B82F6;
  padding: 12rpx 24rpx;
  background: #EFF6FF;
  border-radius: 32rpx;
}

.back-icon {
  font-size: 32rpx;
}

.header-badge {
  background: linear-gradient(135deg, #FF6B6B, #FF8E53);
  color: #FFFFFF;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
}

/* 内容滚动区域 */
.content {
  flex: 1;
  padding: 32rpx;
  padding-bottom: 160rpx;
}

/* 标题卡片 */
.title-card {
  background: linear-gradient(135deg, #3B82F6, #8B5CF6);
  border-radius: 32rpx;
  padding: 48rpx;
  text-align: center;
  box-shadow: 0 8rpx 32rpx rgba(59, 130, 246, 0.2);
  margin-bottom: 32rpx;
}

.title-icon {
  margin-bottom: 24rpx;
}

.icon-heart {
  font-size: 80rpx;
}

.title-text {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.title-subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.9);
  line-height: 1.6;
}

/* 卡片通用样式 */
.content-card, .concepts-card, .promises-card {
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  margin-bottom: 24rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-icon {
  font-size: 40rpx;
}

.card-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1F2937;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6B7280;
  margin-top: 8rpx;
}

/* 内容框 */
.content-box {
  background: linear-gradient(135deg, #F0F9FF, #EEF2FF);
  border-radius: 20rpx;
  padding: 32rpx;
  border-left: 6rpx solid #3B82F6;
}

.content-text {
  font-size: 28rpx;
  line-height: 1.8;
  color: #374151;
  white-space: pre-wrap;
}

/* 健康理念网格 */
.concepts-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 20rpx;
}

.concept-item {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  border: 2rpx solid;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.concept-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  margin-bottom: 16rpx;
}

.concept-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.concept-desc {
  font-size: 24rpx;
  color: #6B7280;
  line-height: 1.5;
}

/* 行动承诺列表 */
.promises-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.promise-item {
  display: flex;
  align-items: flex-start;
  gap: 24rpx;
  padding: 28rpx;
  border-radius: 20rpx;
  border: 2rpx solid #E5E7EB;
}

.promise-num {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  flex-shrink: 0;
}

.promise-content {
  flex: 1;
}

.promise-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #1F2937;
  margin-bottom: 8rpx;
}

.promise-desc {
  font-size: 26rpx;
  color: #6B7280;
  line-height: 1.5;
}

/* 继续按钮 */
.action-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: linear-gradient(to top, #FFFFFF 80%, transparent);
  box-shadow: 0 -8rpx 24rpx rgba(0, 0, 0, 0.05);
}

.btn-continue {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #3B82F6, #8B5CF6);
  color: #FFFFFF;
  font-size: 32rpx;
  font-weight: bold;
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-shadow: 0 8rpx 24rpx rgba(59, 130, 246, 0.3);
}

.btn-continue:active {
  opacity: 0.9;
  transform: scale(0.98);
}
