<!--pages/inspiration/inspiration.wxml-->
<!--发心感悟页面 - 为什么做健康行业-->

<view class="container">
  <!-- 头部导航 -->
  <view class="header">
    <view class="back-btn" bindtap="goBack">
      <text class="back-icon">←</text>
      <text>返回上一步</text>
    </view>
    <view class="header-badge">发心感悟</view>
  </view>

  <!-- 主要内容 -->
  <scroll-view scroll-y class="content">
    <!-- 标题卡片 -->
    <view class="title-card">
      <view class="title-icon">
        <text class="icon-heart">❤️</text>
      </view>
      <view class="title-text">{{title}}</view>
      <view class="title-subtitle">{{subtitle}}</view>
    </view>

    <!-- 发心内容 -->
    <view class="content-card">
      <view class="card-header">
        <text class="card-icon">💭</text>
        <text class="card-title">发心感悟</text>
      </view>
      <view class="card-desc">健康调理不仅需要方法，更需要用心</view>
      <view class="content-box">
        <text class="content-text">{{content}}</text>
      </view>
    </view>

    <!-- 健康理念 -->
    <view class="concepts-card">
      <view class="card-header">
        <text class="card-title">健康理念</text>
        <text class="card-desc">我们的健康调理核心理念</text>
      </view>
      
      <view class="concepts-grid">
        <view wx:for="{{healthConcepts}}" wx:key="title" class="concept-item" style="border-color: {{item.color}};">
          <view class="concept-icon" style="background: {{item.color}};">{{item.icon}}</view>
          <view class="concept-title">{{item.title}}</view>
          <view class="concept-desc">{{item.desc}}</view>
        </view>
      </view>
    </view>

    <!-- 行动承诺 -->
    <view class="promises-card">
      <view class="card-header">
        <text class="card-title">行动承诺</text>
        <text class="card-desc">现在开始，为自己的健康做出承诺</text>
      </view>
      
      <view class="promises-list">
        <view wx:for="{{actionPromises}}" wx:key="title" class="promise-item" style="background: linear-gradient(135deg, {{item.color}}15, {{item.color}}05);">
          <view class="promise-num" style="background: {{item.color}};">{{item.num}}</view>
          <view class="promise-content">
            <view class="promise-title">{{item.title}}</view>
            <view class="promise-desc">{{item.desc}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 继续按钮 -->
    <view class="action-section">
      <button class="btn-continue" bindtap="handleContinue">
        开始健康管理 →
      </button>
    </view>
  </scroll-view>
</view>
