/* pages/history-list/history-list.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #f0f9ff 0%, #e0f2fe 100%);
  padding-bottom: 120rpx;
}

/* 头部 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: white;
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.header-right {
  width: 80rpx;
}

/* 统计卡片 */
.stats-card {
  display: flex;
  justify-content: space-around;
  padding: 32rpx;
  margin: 24rpx;
  background: white;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.stats-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: 700;
  color: #3b82f6;
}

.stats-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 8rpx;
}

/* 操作栏 */
.action-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 32rpx;
  background: white;
  margin: 0 24rpx;
  border-radius: 16rpx;
}

.select-tip {
  font-size: 26rpx;
  color: #6b7280;
}

.action-right {
  display: flex;
  gap: 24rpx;
}

.action-btn {
  font-size: 26rpx;
  color: #3b82f6;
  font-weight: 500;
}

/* 记录列表 */
.list-container {
  padding: 24rpx;
}

.record-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin-bottom: 20rpx;
  background: white;
  border-radius: 16rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.05);
  border: 3rpx solid transparent;
  transition: all 0.3s ease;
}

.record-card.selected {
  border-color: #3b82f6;
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
  box-shadow: 0 4rpx 20rpx rgba(59, 130, 246, 0.25);
  transform: scale(1.02);
}

.select-box {
  margin-right: 20rpx;
}

.checkbox {
  width: 48rpx;
  height: 48rpx;
  border: 3rpx solid #d1d5db;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: white;
  transition: all 0.3s ease;
}

.checkbox.checked {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  border-color: #3b82f6;
  box-shadow: 0 2rpx 8rpx rgba(59, 130, 246, 0.4);
}

.check-icon {
  color: white;
  font-size: 28rpx;
  font-weight: 700;
}

.record-content {
  flex: 1;
}

.record-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 16rpx;
}

.record-index {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.record-date {
  font-size: 24rpx;
  color: #6b7280;
}

.record-body {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.record-score {
  display: flex;
  align-items: baseline;
  margin-right: 32rpx;
}

.score-value {
  font-size: 48rpx;
  font-weight: 700;
}

.score-label {
  font-size: 24rpx;
  margin-left: 4rpx;
}

.record-stats {
  display: flex;
  gap: 24rpx;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-num {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
}

.stat-name {
  font-size: 20rpx;
  color: #9ca3af;
}

.record-footer {
  padding-top: 12rpx;
  border-top: 1rpx solid #f3f4f6;
}

.elements-row {
  display: flex;
  align-items: center;
}

.elements-label {
  font-size: 24rpx;
  color: #6b7280;
}

.elements-value {
  font-size: 24rpx;
  color: #3b82f6;
  font-weight: 500;
}

.delete-btn {
  padding: 16rpx;
  margin-left: 12rpx;
}

.delete-icon {
  font-size: 28rpx;
  color: #9ca3af;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 48rpx;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #6b7280;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #9ca3af;
  text-align: center;
}

/* 加载状态 */
.loading-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx;
}

.loading-icon {
  font-size: 60rpx;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 28rpx;
  color: #6b7280;
  margin-top: 16rpx;
}

/* 底部按钮 */
.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 24rpx 32rpx;
  background: white;
  border-top: 1rpx solid #e5e7eb;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.compare-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 16rpx;
  font-size: 32rpx;
  font-weight: 600;
  border: none;
}

.compare-btn.active {
  background: linear-gradient(135deg, #3b82f6, #2563eb);
  color: white;
}

.compare-btn.disabled {
  background: #e5e7eb;
  color: #9ca3af;
}

/* 弹窗 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 80%;
  background: white;
  border-radius: 20rpx;
  padding: 40rpx;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  text-align: center;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #6b7280;
  text-align: center;
  margin-bottom: 32rpx;
}

.modal-btns {
  display: flex;
  gap: 24rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  border-radius: 12rpx;
  font-size: 28rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  background: #f3f4f6;
  color: #6b7280;
}

.modal-btn.confirm {
  background: #ef4444;
  color: white;
}
