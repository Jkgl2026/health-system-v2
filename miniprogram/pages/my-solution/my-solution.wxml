<!--pages/my-solution/my-solution.wxml-->
<view class="container">
  <view class="header">
    <text class="header-title">我的健康方案</text>
  </view>
  
  <!-- 用户信息 -->
  <view class="user-card">
    <view class="user-avatar">👤</view>
    <view class="user-info">
      <text class="user-name">{{userInfo.name || '用户'}}</text>
      <text class="user-detail">{{userInfo.age}}岁 · {{userInfo.gender}} · BMI: {{userInfo.bmi || '--'}}</text>
    </view>
  </view>
  
  <!-- 健康评分 -->
  <view class="score-card">
    <text class="score-label">健康评分</text>
    <text class="score-value">{{healthScore}}</text>
    <view class="score-bar"><view class="score-fill" style="width: {{healthScore}}%;"></view></view>
  </view>
  
  <!-- 重点症状 -->
  <view class="section-card">
    <text class="section-title">🎯 重点改善症状</text>
    <view class="target-list">
      <view wx:for="{{targetSymptoms}}" wx:key="*this" class="target-item">
        <text class="target-num">{{index + 1}}</text>
        <text class="target-name">{{item}}</text>
      </view>
    </view>
  </view>
  
  <!-- 调理方案 -->
  <view class="section-card">
    <text class="section-title">📋 调理方案</text>
    <view class="plan-list">
      <view class="plan-item">
        <text class="plan-phase">第一阶段：清理排毒</text>
        <text class="plan-desc">通过艾灸调理，清理体内毒素</text>
      </view>
      <view class="plan-item">
        <text class="plan-phase">第二阶段：补益调理</text>
        <text class="plan-desc">补充气血，调理脏腑功能</text>
      </view>
      <view class="plan-item">
        <text class="plan-phase">第三阶段：巩固养护</text>
        <text class="plan-desc">建立健康生活习惯，巩固疗效</text>
      </view>
    </view>
  </view>
  
  <view class="bottom-actions">
    <button class="btn btn-primary btn-block" bindtap="goToStory">了解系统战役故事 →</button>
  </view>
</view>
