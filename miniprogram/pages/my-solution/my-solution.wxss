/* pages/my-solution/my-solution.wxss */
.container { min-height: 100vh; background: #f5f5f5; padding-bottom: 160rpx; }
.header { padding: 32rpx; background: linear-gradient(135deg, #6366f1, #8b5cf6); color: #fff; text-align: center; }
.header-title { font-size: 36rpx; font-weight: 700; }
.user-card { display: flex; align-items: center; gap: 20rpx; margin: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; }
.user-avatar { width: 80rpx; height: 80rpx; background: #e5e7eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 40rpx; }
.user-name { display: block; font-size: 32rpx; font-weight: 600; color: #1f2937; }
.user-detail { display: block; font-size: 24rpx; color: #6b7280; margin-top: 4rpx; }
.score-card { margin: 24rpx; padding: 32rpx; background: linear-gradient(135deg, #10b981, #059669); border-radius: 16rpx; color: #fff; text-align: center; }
.score-label { display: block; font-size: 24rpx; opacity: 0.9; }
.score-value { display: block; font-size: 64rpx; font-weight: 700; margin: 16rpx 0; }
.score-bar { height: 12rpx; background: rgba(255,255,255,0.3); border-radius: 6rpx; overflow: hidden; }
.score-fill { height: 100%; background: #fff; border-radius: 6rpx; }
.section-card { margin: 24rpx; padding: 24rpx; background: #fff; border-radius: 16rpx; }
.section-title { display: block; font-size: 30rpx; font-weight: 600; color: #1f2937; margin-bottom: 20rpx; }
.target-list { display: flex; flex-direction: column; gap: 16rpx; }
.target-item { display: flex; align-items: center; gap: 16rpx; padding: 16rpx; background: #fef2f2; border-radius: 12rpx; }
.target-num { width: 40rpx; height: 40rpx; background: #ef4444; color: #fff; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 24rpx; font-weight: 700; }
.target-name { font-size: 28rpx; color: #1f2937; }
.plan-list { display: flex; flex-direction: column; gap: 16rpx; }
.plan-item { padding: 20rpx; background: #f9fafb; border-radius: 12rpx; border-left: 6rpx solid #10b981; }
.plan-phase { display: block; font-size: 28rpx; font-weight: 600; color: #1f2937; margin-bottom: 8rpx; }
.plan-desc { display: block; font-size: 24rpx; color: #6b7280; }
.bottom-actions { padding: 24rpx; background: #fff; position: fixed; bottom: 0; left: 0; right: 0; }
.btn { display: flex; align-items: center; justify-content: center; padding: 24rpx; border-radius: 16rpx; font-size: 28rpx; }
.btn-primary { background: linear-gradient(90deg, #3b82f6, #10b981); color: #fff; }
.btn-block { width: 100%; }
