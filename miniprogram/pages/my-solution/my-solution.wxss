/* pages/my-solution/my-solution.wxss */
/* 个性化健康管理方案页面样式 - 1:1复刻Web版 */

.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #dbeafe 0%, #ffffff 50%, #dcfce7 100%);
  padding-bottom: 40rpx;
}

/* 头部导航 */
.header {
  position: sticky;
  top: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 32rpx;
  background: rgba(255, 255, 255, 0.9);
  backdrop-filter: blur(10px);
  border-bottom: 1rpx solid #e5e7eb;
}

.back-btn {
  display: flex;
  align-items: center;
  color: #6b7280;
  font-size: 28rpx;
}

.back-icon {
  margin-right: 8rpx;
  font-size: 32rpx;
}

.header-badge {
  padding: 8rpx 24rpx;
  border: 2rpx solid #86efac;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #15803d;
  background: #dcfce7;
}

/* 内容 */
.content {
  padding: 32rpx;
}

/* 欢迎卡片 */
.welcome-card {
  background: white;
  border-radius: 24rpx;
  padding: 48rpx 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #86efac;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
  text-align: center;
}

.welcome-icon {
  width: 96rpx;
  height: 96rpx;
  background: linear-gradient(135deg, #22c55e, #3b82f6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  margin: 0 auto 24rpx auto;
}

.welcome-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #111827;
  margin-bottom: 16rpx;
}

.welcome-desc {
  font-size: 28rpx;
  color: #6b7280;
  line-height: 1.6;
}

/* 总结卡片 */
.summary-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 2rpx solid #e5e7eb;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 24rpx;
}

/* 重点症状 */
.target-section {
  padding: 24rpx;
  background: #eff6ff;
  border-radius: 16rpx;
  border: 4rpx solid #93c5fd;
  margin-bottom: 24rpx;
}

.target-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 16rpx;
}

.target-list {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.target-item {
  font-size: 28rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.target-num {
  margin-right: 8rpx;
}

/* 统计网格 */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.stats-item {
  padding: 24rpx;
  border-radius: 16rpx;
  border: 4rpx solid;
}

.stats-green {
  background: linear-gradient(135deg, #f0fdf4, #d1fae5);
  border-color: #86efac;
}

.stats-purple {
  background: linear-gradient(135deg, #faf5ff, #f3e8ff);
  border-color: #c4b5fd;
}

.stats-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.stats-icon {
  font-size: 28rpx;
  margin-right: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  font-weight: 700;
  color: #111827;
}

.stats-value-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
}

.stats-label-text {
  font-size: 24rpx;
  color: #374151;
}

.stats-value {
  font-size: 36rpx;
  font-weight: 700;
  color: #15803d;
}

.stats-bar {
  width: 100%;
  height: 24rpx;
  background: #e5e7eb;
  border-radius: 12rpx;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.stats-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.5s;
}

.stats-fill-green {
  background: linear-gradient(90deg, #22c55e, #10b981);
}

.stats-note {
  font-size: 20rpx;
  color: #6b7280;
  text-align: center;
}

/* 健康要素列表 */
.element-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.element-item {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.element-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.element-name {
  font-size: 24rpx;
  font-weight: 600;
  color: #111827;
}

.element-count {
  font-size: 24rpx;
  font-weight: 700;
  color: #7c3aed;
}

.element-bar {
  width: 100%;
  height: 20rpx;
  background: #e5e7eb;
  border-radius: 10rpx;
  overflow: hidden;
}

.element-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 0.5s;
}

.empty-text {
  font-size: 24rpx;
  color: #6b7280;
  text-align: center;
  padding: 24rpx 0;
}

/* 选择方案 */
.choice-section {
  padding: 20rpx;
  background: #fff7ed;
  border-radius: 12rpx;
  border: 4rpx solid #fdba74;
}

.choice-label {
  font-size: 24rpx;
  font-weight: 600;
  color: #374151;
  margin-bottom: 8rpx;
}

.choice-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #c2410c;
}

/* 产品卡片 */
.products-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #bfdbfe;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.card-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.card-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.card-desc {
  font-size: 26rpx;
  color: #6b7280;
  margin-bottom: 24rpx;
}

.products-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16rpx;
}

.product-item {
  padding: 20rpx;
  background: white;
  border-radius: 16rpx;
  border: 2rpx solid #e5e7eb;
}

.product-header {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.product-icon {
  width: 48rpx;
  height: 48rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  margin-right: 12rpx;
}

.product-info {
  flex: 1;
}

.product-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #111827;
}

.product-match {
  font-size: 20rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  display: inline-block;
  margin-top: 4rpx;
}

.product-desc {
  font-size: 22rpx;
  color: #374151;
  margin-bottom: 12rpx;
  line-height: 1.5;
}

.product-reasons {
  background: #f9fafb;
  padding: 12rpx;
  border-radius: 8rpx;
}

.reasons-title {
  font-size: 20rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.reason-item {
  font-size: 20rpx;
  color: #4b5563;
  line-height: 1.6;
  display: flex;
  align-items: flex-start;
}

.reason-dot {
  color: #22c55e;
  margin-right: 4rpx;
}

/* 课程卡片 */
.courses-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #f3e8ff;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.05);
}

.courses-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.course-item {
  padding: 16rpx;
  background: white;
  border-radius: 12rpx;
  border: 2rpx solid #e5e7eb;
}

.course-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.course-badge {
  font-size: 18rpx;
  color: #6b7280;
  background: #f3f4f6;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.course-highlight {
  font-size: 18rpx;
  color: white;
  background: #ef4444;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.course-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 6rpx;
  line-height: 1.4;
}

.course-content {
  font-size: 18rpx;
  color: #6b7280;
  line-height: 1.5;
  margin-bottom: 8rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.course-meta {
  font-size: 18rpx;
  color: #9ca3af;
}

/* 提示卡片 */
.notice-card {
  display: flex;
  padding: 24rpx;
  background: #fff7ed;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
  border: 4rpx solid #fdba74;
}

.notice-icon {
  font-size: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.notice-content {
  flex: 1;
}

.notice-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 8rpx;
}

.notice-text {
  font-size: 24rpx;
  color: #374151;
  line-height: 1.6;
}

/* 完成卡片 */
.complete-card {
  background: white;
  border-radius: 24rpx;
  padding: 32rpx;
  border: 4rpx solid #86efac;
  text-align: center;
}

.complete-icon {
  font-size: 48rpx;
  margin-bottom: 16rpx;
}

.complete-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
  margin-bottom: 12rpx;
}

.complete-desc {
  font-size: 26rpx;
  color: #6b7280;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.btn-courses {
  width: 100%;
  padding: 24rpx;
  background: linear-gradient(135deg, #22c55e, #3b82f6);
  color: white;
  font-size: 28rpx;
  font-weight: 600;
  border-radius: 16rpx;
  border: none;
}

/* 新增课程样式 */
.course-highlight-item {
  border-color: #fca5a5;
  background: #fff5f5;
}

.course-common {
  font-size: 18rpx;
  color: white;
  background: #6366f1;
  padding: 2rpx 8rpx;
  border-radius: 6rpx;
}

.course-duration {
  color: #6b7280;
}

.course-element {
  margin-left: 8rpx;
  color: #22c55e;
  font-weight: 500;
}

.reason-item-text {
  font-size: 20rpx;
  color: #4b5563;
  line-height: 1.6;
  display: flex;
  align-items: flex-start;
}

.reason-item-text .reason-dot {
  color: #22c55e;
  margin-right: 4rpx;
  flex-shrink: 0;
}
